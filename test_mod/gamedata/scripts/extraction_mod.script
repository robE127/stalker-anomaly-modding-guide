-- extraction_mod.script
-- Extraction Shooter Mode for S.T.A.L.K.E.R. Anomaly
--
-- Rules:
--   1. Player can only save within a friendly base area.
--   2. All saves (quicksave, menu save, autosave) are redirected to a single
--      fixed file "extraction_save". Any save to a different name is deleted
--      and replaced with the fixed file. MCM can assign a base hotkey to set
--      exact respawn at your feet while in a friendly base (hotkey never saves).
--   3. On death: full inventory transferred into an inv_backpack stash spawned
--      at the death location. Player teleports to the last recorded friendly base.
--   4. Night respawn: if death occurs 20:00–08:00 advance time to 08:00.
--   5. Optional: prior death stashes can lose random items over in-game time
--      (MCM + extraction_mod_config.ltx [stash_npc_looting], interval in hours);
--      empty stashes are removed and PDA markers cleared.
--
-- REQUIREMENTS:
--   Modded exes (xray-monolith) required for actor_on_before_death.
--
-- DOCUMENTATION GAPS (things that required reading community mod source or engine
-- source to discover):
--   [GAP-1] exec_console_cmd  -- not in guide; confirmed by Jabbers Soulslike source.
--   [GAP-2] "inv_backpack" section name  -- not in guide; confirmed by Jabbers source.
--   [GAP-3] ui_load_dialog.delete_save_game(name)  -- not in guide; found in
--           Jabbers Soulslike source. Takes lowercase filename without extension.
--           Should be documented under a "save file management" API page.
--   [GAP-4] db.actor_inside_zones  -- not in guide; found in Fair Fast Travel.
--           Using distance check as fallback. Should be documented.
--   [GAP-5] Level name strings not listed in guide. Using examples from level.md
--           plus inference; names marked (?) are unverified.
--   [GAP-6] game_relations.is_factions_friends(f1, f2) -- not in guide; confirmed
--           from game_relations.script. Returns true if community_relation >= FRIENDS.
--   [GAP-7] get_actor_true_community() -- global in _g.script; calls
--           gameplay_disguise.get_default_comm(). Returns the player's true faction
--           string regardless of current disguise.
--   [GAP-8] Level transition autosaves: on_console_execute fires BEFORE the file
--           is written during level changes (pre-notification, not post). Calling
--           delete_save_game inside that callback deletes a file that doesn't
--           exist yet; the engine then writes it after the callback returns.
--           Fix: delete the expected autosave name in actor_on_first_update,
--           which fires after the new level fully loads and the file is on disk.
--   [GAP-9] Per-script environments (confirmed in script_storage.cpp): each
--           .script file runs in its own environment table (`this`) with
--           setmetatable(this, {__index = _G}) + setfenv(1, this). Reads fall
--           through to _G; writes only affect `this`. Consequence: reassigning
--           a global function (e.g. exec_console_cmd = wrapped) only affects your
--           own script -- other scripts still see the original from _G. To hook
--           base game class behaviour, patch the class table directly:
--           cls.method = new_fn (visible to all, because the class table IS in _G).
--           Now documented in docs/scripting/lua-scope.md.
--
-- KNOWN ISSUES:
--   • Level names sourced from Fair Fast Travel travel_destinations.ltx
--     [northern_maps] section -- all main-game levels now confirmed.
--   • Limansk (l10_limansk) zone coordinates are unconfirmed (?); level name
--     itself is confirmed from travel_destinations.ltx.
--   • Late-game levels (Pripyat, Red Forest, Dead City) not included.

-- ─────────────────────────────────────────────────────────────────────────────
-- Safe zone table
-- Populated at game start by load_config() from extraction_mod_zones.ltx.
-- Format after loading:
--   SAFE_ZONES[level_name] = { { name, level, x, y, z, radius, owner, respawn_x, ... }, ... }
-- owner is a faction community string or nil (nil = open to all factions).
-- SAFE_ZONES_BY_NAME[zone_name] holds the same table reference for O(1) lookup.
-- ─────────────────────────────────────────────────────────────────────────────

local SAFE_ZONES         = {}
local SAFE_ZONES_BY_NAME = {}  -- zone_name -> zone table (same refs as SAFE_ZONES)
local SAFE_ZONES_BY_RESTRICTOR_ID = {} -- spawned restrictor server id -> zone table
local ACTOR_INSIDE_SAFE_ZONE_IDS = {} -- restrictor server id -> true while actor is inside
local SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE = {} -- restrictor server id -> true once enter/exit callbacks are attached
local SAFE_ZONE_RESTRICTOR_SEED_DONE = {} -- restrictor server id -> true after initial inside/outside seeding

-- ─────────────────────────────────────────────────────────────────────────────
-- Configuration
-- ─────────────────────────────────────────────────────────────────────────────

-- All save files written by this mod use this name. The "em_" prefix makes them
-- clearly identifiable as belonging to this mod so file-management operations
-- (delete, list) can target them without risking saves from other playthroughs.
-- The engine writes its own autosaves using user_name() as the prefix; those are
-- intercepted and replaced with this file -- see actor_on_first_update and
-- on_console_execute.
local SAVE_FILENAME   = "em_extraction_save"
local DEFAULT_ZONE_SECTION = "em_safe_zone_restrictor"
-- Reserved stem: copies of `SAVE_FILENAME` on disk before an illegal external
-- save can overwrite them. Removed after deferred cleanup runs.
local SLOT_GUARD_STEM = "em_extraction_save_guard_tmp"

-- Dev CLI overrides file (saves folder). Written by dev_cli_set_zone_respawn /
-- dev_cli_set_zone_center / dev_cli_set_zone_radius; read at end of load_config().
local OVERRIDES_FILE  = "em_spawn_overrides.ltx"

-- Flag file written by on_level_changing to mark that THIS session triggered a
-- level transition. actor_on_first_update checks for this flag before deleting
-- the engine's autosave. Without the flag, a pre-existing "player - autosave"
-- from a separate playthrough would be silently deleted on the first transition.
-- The file is written to the saves folder (same dir as .scop files) and consumed
-- (overwritten with "0") immediately after being read.
local TRANSITION_FLAG = "em_transition_flag"
local SESSION_LOCK_FILE = "em_session_lock"
local MAIN_MENU_LOAD_FLAG = "em_main_menu_load_flag"

local function get_flag_path()
    -- getFS():update_path("$game_saves$", "") returns the absolute path to the
    -- saves folder with a trailing separator (e.g. "C:\...\savedgames\").
    -- Confirmed: alife_storage_manager.script uses the same pattern for io.open.
    return getFS():update_path("$game_saves$", "") .. TRANSITION_FLAG
end

local function get_session_lock_path()
    return getFS():update_path("$game_saves$", "") .. SESSION_LOCK_FILE
end

local function get_main_menu_load_flag_path()
    return getFS():update_path("$game_saves$", "") .. MAIN_MENU_LOAD_FLAG
end

local function read_session_lock_flag()
    local f = io.open(get_session_lock_path(), "r")
    local v = f and f:read("*l") or "0"
    if f then f:close() end
    return v
end

local function write_session_lock_flag(v)
    local f = io.open(get_session_lock_path(), "w")
    if f then
        f:write(v)
        f:close()
    else
        printe("![EM] write_session_lock_flag: failed to write '%s'", get_session_lock_path())
    end
end

local function read_main_menu_load_flag()
    local f = io.open(get_main_menu_load_flag_path(), "r")
    local v = f and f:read("*l") or "0"
    if f then f:close() end
    return v
end

local function write_main_menu_load_flag(v)
    local f = io.open(get_main_menu_load_flag_path(), "w")
    if f then
        f:write(v)
        f:close()
    else
        printe("![EM] write_main_menu_load_flag: failed to write '%s'", get_main_menu_load_flag_path())
    end
end

local function get_overrides_path()
    return getFS():update_path("$game_saves$", "") .. OVERRIDES_FILE
end
local NIGHT_START     = 20
local NIGHT_END       = 8
local UPDATE_INTERVAL = 5000 -- ms between periodic maintenance checks
local STASH_RELEASE_FLUSH_INTERVAL_SEC = 60
local MOD_KEY         = "extraction_mod"
local CHEAT_LOAD_WATERMARK_MSG = "CHEAT LOAD DETECTED - Run invalid: You are now permanently irradiated. Recovery: quit to main menu, then load a valid save. DO NOT SAVE until you have reloaded a valid save."
local FIRST_RUN_BACKUP_DIR_PREFIX = "em_pre_extraction_backup_"

-- ─────────────────────────────────────────────────────────────────────────────
-- MCM
-- ─────────────────────────────────────────────────────────────────────────────

-- Default values used when MCM is not installed.
local MCM_DEFAULTS = {
    show_stash_marker       = true,
    allow_neutral_bases     = false,
    delete_items_on_death   = false,
}

-- Defaults for stash NPC loot when ui_mcm.get returns nil (MCM absent or key
-- never stored). Overwritten from extraction_mod_config.ltx [stash_npc_looting]
-- in load_config().
local stash_loot_ltx_enabled = false

-- Read an MCM option by key. Falls back to MCM_DEFAULTS (or LTX for stash_npc_looting)
-- if MCM is not installed or the key has not been set yet.
-- MCM stores values under "<mod_id>/<key>" in ui_mcm.get().
-- Pattern confirmed from soulslike_mcm.script get_config().
local function mcm_option(key)
    if ui_mcm then
        local v = ui_mcm.get(MOD_KEY .. "/" .. key)
        if v ~= nil then return v end
    end
    if key == "stash_npc_looting" then return stash_loot_ltx_enabled end
    return MCM_DEFAULTS[key]
end

-- Read a numeric MCM option with fallback + clamp.
-- Handles MCM input fields that can arrive as string/number/nil.
local function mcm_number_option_clamped(key, fallback, min_value, max_value)
    local v = nil
    if ui_mcm then
        v = ui_mcm.get(MOD_KEY .. "/" .. key)
    end

    local n = nil
    if type(v) == "string" then
        local trimmed = (v:match("^%s*(.-)%s*$") or "")
        if trimmed ~= "" then
            n = tonumber(trimmed)
        end
    elseif type(v) == "number" then
        n = v
    end

    if n == nil then
        n = fallback
    end
    return math.max(min_value, math.min(max_value, n))
end

-- Returns nil when the player cleared the bind in MCM (0); otherwise a DIK code.
local function mcm_base_hotkey_dik()
    if ui_mcm then
        local v = ui_mcm.get(MOD_KEY .. "/base_hotkey")
        if type(v) == "number" then
            if v == 0 then return nil end
            return v
        end
    end
    return DIK_keys.DIK_F8
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Debug logging
-- ─────────────────────────────────────────────────────────────────────────────

-- debug_log(fmt, ...) writes a formatted line to the log when the game is launched
-- with -dbg (which sets the global DEV_DEBUG = true).
--
-- We gate on DEV_DEBUG rather than a local flag because printf() itself is a
-- no-op in release builds unless -dbg is active: vscript_log() in
-- script_storage.cpp returns 0 immediately without writing if "-dbg" is not
-- in Core.Params. There is no point calling printf() when DEV_DEBUG is false.
--
-- Uses string.format() for interpolation because Anomaly's printf() only
-- replaces %s (via string_gsub); %f and %d are silently dropped.
local function debug_log(fmt, ...)
    if not DEV_DEBUG then return end
    local ok, msg = pcall(string.format, fmt, ...)
    printf("[EM] %s", ok and msg or ("(fmt error) " .. tostring(fmt)))
    -- flush() forces the engine log buffer to disk immediately so output
    -- appears in the live log file rather than only in the .bkp after the
    -- session closes. It is a top-level engine function bound in lua_help.script.
    -- printf() in _g.script has an equivalent exec_console_cmd("flush") call
    -- that is commented out for performance  -- we reinstate it here since this
    -- function is only active under -dbg anyway.
    flush()
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Persistent state   (docs: scripting/save-load.md)
-- ─────────────────────────────────────────────────────────────────────────────

local data = {
    -- Name of the last safe zone entered (e.g. "rookie_village"). Used at
    -- respawn time to look up the current respawn coords from SAFE_ZONES_BY_NAME,
    -- so a dev_cli_set_zone_respawn() change takes effect on the next death without needing
    -- the player to re-enter the zone.
    last_base_name  = nil,
    last_base_level = nil,   -- level name at the time of entry
    -- Navigation vertices captured when the player entered the zone. These
    -- cannot be derived from a world position in Lua and are required by
    -- ChangeLevel for cross-level respawn.
    last_base_lvid  = nil,
    last_base_gvid  = nil,
    -- Set of server IDs for death stashes that currently have a PDA marker.
    -- Persisted so markers survive save/load. Keyed by ID (number -> true).
    stash_ids       = {},
    -- All death stashes we spawned (with or without a PDA marker). Used for
    -- optional NPC-loot simulation and for removing empty stashes from the world.
    death_stash_ids = {},
    -- Empty stashes that were online when they became empty. We defer releasing
    -- those until they go offline to avoid deleting a container while it is open
    -- in UI (can crash with stale engine references).
    pending_stash_release_ids = {},
    -- game.time() (in-game ms since epoch) when we last ran the interval loot pulse.
    -- Stored as a number so we never call CTime() — that global is not available
    -- from this script environment in some builds (see tick_death_stash_npc_loot_by_game_time).
    last_stash_loot_game_ms = nil,
    -- Spawned safe-zone restrictor server ids keyed by configured zone name (session only).
    -- Persisted in save_state/load_state; values are validated each load and
    -- recreated when missing/invalid.
    safe_zone_restrictor_ids = {},
    -- Set after suspicious mid-session loads that bypass normal load blockers.
    -- Persisted to keep a run visibly invalid after detection.
    tainted_by_forbidden_load = false,
    -- Per-playthrough first-run marker. False means this playthrough has not yet
    -- run initial save migration/forced extraction save bootstrap.
    first_run_migration_done = false,
}

-- ─────────────────────────────────────────────────────────────────────────────
-- Helpers
-- ─────────────────────────────────────────────────────────────────────────────

local function show_msg(text)
    actor_menu.set_msg(1, "[Extraction] " .. text, 5)
end

-- Returns the matched zone table (truthy) when the actor is inside a friendly
-- safe zone, nil otherwise. Callers that only need a boolean can use the return
-- value directly in an `if` test; callers that need zone data (e.g. to read the
-- configured respawn position) can use the returned table directly.
local function safe_zone_allowed_for_player_faction(z)
    if not z.owner then
        return true
    end
    local player_faction = get_actor_true_community()
    if not player_faction then
        return false
    end
    if game_relations.is_factions_friends(player_faction, z.owner) then
        return true
    end
    return mcm_option("allow_neutral_bases")
        and game_relations.is_factions_neutrals(player_faction, z.owner)
end

local function get_friendly_safe_zone_actor_is_inside()
    if not (db.actor and db.actor:alive()) then return nil end
    for restrictor_id, _ in pairs(ACTOR_INSIDE_SAFE_ZONE_IDS) do
        local z = SAFE_ZONES_BY_RESTRICTOR_ID[restrictor_id]
        if z and safe_zone_allowed_for_player_faction(z) then
            return z
        end
    end
    return nil
end

local function is_night(h)
    h = h or level.get_time_hours()
    return h >= NIGHT_START or h < NIGHT_END
end

local function hours_until_dawn(h)
    h = h or level.get_time_hours()
    if h >= NIGHT_END and h < NIGHT_START then return 0 end
    if h >= NIGHT_START then
        -- this is for hours from NIGHT_START up to midnight (0)
        return (24 - h) + NIGHT_END
    else
        -- this is for from midnight (hour 0) through NIGHT_END
        return NIGHT_END - h
    end
end

-- Record which safe zone the player last entered. The zone name is persisted
-- so that at respawn time we can look up the current respawn coords from
-- SAFE_ZONES_BY_NAME -- meaning a dev_cli_set_zone_respawn() change takes effect on the next
-- death without needing to re-enter the zone.
-- Navigation vertices (lvid/gvid) are captured from the actor here because
-- there is no engine API to derive them from a world position later; they are
-- needed by ChangeLevel for cross-level respawn.
local function record_respawn_base_from_zone(zone)
    if not (db.actor and db.actor:alive()) then return end
    data.last_base_name  = zone.name
    data.last_base_level = level.name()
    data.last_base_lvid  = db.actor:level_vertex_id()
    data.last_base_gvid  = db.actor:game_vertex_id()
    debug_log("record_respawn_base_from_zone: name=%s level=%s lvid=%s gvid=%s",
        zone.name, data.last_base_level,
        tostring(data.last_base_lvid), tostring(data.last_base_gvid))
end

-- Set to true for the duration of our own exec_console_cmd("save ...") call.
-- Lets on_console_execute skip the zone check only for saves WE triggered,
-- not for any external call that happens to use our filename.
local save_in_progress = false

-- Populated when save_state sees an external save (C++ console, engine path,
-- etc.): fingerprint of our slot before the engine writes, safe-zone flag, and
-- whether we copied the live slot to SLOT_GUARD_STEM (illegal saves cannot be
-- blocked pre-write from Lua; we restore from that copy when needed).
local external_save_cleanup_ctx = nil
local load_state_seen_this_session = false
local suppress_external_save_cleanup_once = false


-- Set of item section names to keep in the player's inventory on death.
-- Populated from extraction_mod_config.ltx [keep_on_death] at game start.
local keep_on_death = {}

-- Hours of in-game time between automatic stash loot pulses (0 = disable).
-- Read from LTX each load_config() as fallback when ui_mcm has no value, or when
-- the MCM text field is empty / not a number (so the game stays usable).
local stash_loot_interval_hours = 1
-- Percent chance (0..100) that each tracked stash loses one random item during
-- a pulse. Rolled independently per stash.
local stash_loot_delete_chance_percent = 25

local function stash_loot_interval_hours_resolved()
    return mcm_number_option_clamped("stash_loot_interval_hours", stash_loot_interval_hours, 0, math.huge)
end

local function refresh_stash_loot_delete_chance_percent(source)
    stash_loot_delete_chance_percent = mcm_number_option_clamped(
        "stash_loot_delete_chance_percent",
        stash_loot_delete_chance_percent,
        0,
        100
    )
    debug_log("refresh_stash_loot_delete_chance_percent: source=%s value=%.2f",
        tostring(source), stash_loot_delete_chance_percent)
end

-- Forward declaration: load_spawn_overrides is defined after load_config but
-- called from within it. Lua resolves the local variable at call time, so
-- declaring it here lets load_config capture it as an upvalue rather than
-- falling back to a (non-existent) global lookup.
local load_spawn_overrides

local function load_config()
    -- ── Keep-on-death list ────────────────────────────────────────────────────
    local ini = ini_file("extraction_mod_config.ltx")
    if not ini:section_exist("keep_on_death") then
        debug_log("load_config: [keep_on_death] section not found -- nothing kept on death")
    else
        local n = ini:line_count("keep_on_death")
        for i = 0, n - 1 do
            local _, key, _ = ini:r_line("keep_on_death", i, "", "")
            if key and key ~= "" then
                keep_on_death[key] = true
                debug_log("load_config: keep_on_death += %s", key)
            end
        end
        debug_log("load_config: %d section(s) configured to keep on death", n)
    end

    -- ── Stash NPC loot (optional) ─────────────────────────────────────────────
    -- These are the fallback when MCM is absent or the interval
    -- text field is empty / invalid (see stash_loot_interval_hours_resolved()).
    stash_loot_interval_hours = 12
    stash_loot_delete_chance_percent = 75
    stash_loot_ltx_enabled = false
    if ini:section_exist("stash_npc_looting") then
        if ini:line_exist("stash_npc_looting", "enabled") then
            stash_loot_ltx_enabled = ini:r_bool("stash_npc_looting", "enabled")
        end
        if ini:line_exist("stash_npc_looting", "interval_game_hours") then
            stash_loot_interval_hours = math.max(0, ini:r_float("stash_npc_looting", "interval_game_hours"))
        end
        if ini:line_exist("stash_npc_looting", "delete_chance_percent") then
            stash_loot_delete_chance_percent = math.max(0, math.min(100,
                ini:r_float("stash_npc_looting", "delete_chance_percent")))
        end
        debug_log("load_config: stash_npc_looting enabled=%s interval_game_hours=%.3f delete_chance_percent=%.2f",
            tostring(stash_loot_ltx_enabled), stash_loot_interval_hours, stash_loot_delete_chance_percent)
    end
    refresh_stash_loot_delete_chance_percent("load_config")

    -- ── Safe zones ────────────────────────────────────────────────────────────
    -- Rebuild from scratch each time so a reload always reflects the LTX.
    SAFE_ZONES         = {}
    SAFE_ZONES_BY_NAME = {}
    SAFE_ZONES_BY_RESTRICTOR_ID = {}
    ACTOR_INSIDE_SAFE_ZONE_IDS = {}
    SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE = {}
    SAFE_ZONE_RESTRICTOR_SEED_DONE = {}
    local zones_ini = ini_file("extraction_mod_zones.ltx")
    if not zones_ini:section_exist("zones") then
        debug_log("load_config: [zones] section not found in extraction_mod_zones.ltx -- no safe zones")
        return
    end
    local zone_count = 0
    local n = zones_ini:line_count("zones")
    for i = 0, n - 1 do
        local _, zone_name, _ = zones_ini:r_line("zones", i, "", "")
        if zone_name and zone_name ~= "" then
            if not zones_ini:section_exist(zone_name) then
                debug_log("load_config: zone '%s' listed in [zones] but has no section -- skipping", zone_name)
            else
                local level_name = zones_ini:r_string(zone_name, "level")
                -- owner is optional; line_exist guards against r_string failing
                -- on a missing key.
                local owner = zones_ini:line_exist(zone_name, "owner")
                    and zones_ini:r_string(zone_name, "owner")
                    or nil
                local x      = zones_ini:r_float(zone_name, "x")
                local y      = zones_ini:r_float(zone_name, "y")
                local z      = zones_ini:r_float(zone_name, "z")
                local radius = zones_ini:r_float(zone_name, "radius")
                local zone_section = zones_ini:line_exist(zone_name, "zone_section")
                    and zones_ini:r_string(zone_name, "zone_section")
                    or DEFAULT_ZONE_SECTION

                -- respawn_x/y/z default to the zone center when omitted.
                local rx = zones_ini:line_exist(zone_name, "respawn_x")
                    and zones_ini:r_float(zone_name, "respawn_x") or x
                local ry = zones_ini:line_exist(zone_name, "respawn_y")
                    and zones_ini:r_float(zone_name, "respawn_y") or y
                local rz = zones_ini:line_exist(zone_name, "respawn_z")
                    and zones_ini:r_float(zone_name, "respawn_z") or z

                -- respawn_dir is optional; nil means "leave facing unchanged".
                local rdir = zones_ini:line_exist(zone_name, "respawn_dir")
                    and zones_ini:r_float(zone_name, "respawn_dir")
                    or nil

                if not SAFE_ZONES[level_name] then
                    SAFE_ZONES[level_name] = {}
                end
                local zone_entry = {
                    name = zone_name,
                    level = level_name, -- map id string (same as extraction_mod_zones "level" key)
                    x = x, y = y, z = z, radius = radius, owner = owner,
                    zone_section = zone_section,
                    respawn_x = rx, respawn_y = ry, respawn_z = rz,
                    respawn_dir = rdir,
                }
                table.insert(SAFE_ZONES[level_name], zone_entry)
                SAFE_ZONES_BY_NAME[zone_name] = zone_entry
                zone_count = zone_count + 1
                debug_log("load_config: zone '%s' level=%s owner=%s center=(%.2f,%.2f,%.2f) r=%.0f respawn=(%.2f,%.2f,%.2f) dir=%s",
                    zone_name, level_name, tostring(owner), x, y, z, radius, rx, ry, rz,
                    rdir and string.format("%.4f", rdir) or "nil")
            end
        end
    end
    debug_log("load_config: loaded %d safe zones across %d levels", zone_count, (function()
        local c = 0; for _ in pairs(SAFE_ZONES) do c = c + 1 end; return c
    end)())

    -- Apply any dev CLI overrides (em_spawn_overrides.ltx).
    load_spawn_overrides()
end

-- ═════════════════════════════════════════════════════════════════════════════
-- DEVELOPER CLI TOOLS  (console / run_string while tuning extraction_mod_zones.ltx)
--
-- Prefer the dev_cli_* names; set_zone_spawn / set_zone_center / set_zone_radius are shorter aliases.
--
--   run_string extraction_mod.dev_cli_set_zone_respawn("rookie_village")
--   run_string extraction_mod.dev_cli_set_zone_center("rookie_village")
--   run_string extraction_mod.dev_cli_set_zone_radius("rookie_village")
--   run_string extraction_mod.set_zone_spawn("rookie_village")
--   run_string extraction_mod.set_zone_center("rookie_village")
--   run_string extraction_mod.set_zone_radius("rookie_village")
--
-- Omit the string argument while standing inside a friendly safe zone to target
-- that zone (same for both commands).
--
-- Overrides apply to SAFE_ZONES immediately and are written to em_spawn_overrides.ltx
-- in the saves folder; load_config() merges that file on every game start.
-- On the zone's configured map, dev_cli_set_zone_center / dev_cli_set_zone_radius
-- recreate the restrictor (new position or sphere size).
--
-- To commit values permanently, copy the printed section into extraction_mod_zones.ltx
-- and trim or delete the overrides file (or delete the file to revert all overrides).
--
-- Console feedback uses printf. debug_log lines require -dbg.
--
-- load_spawn_overrides is defined next (must stay immediately after load_config).
-- write_spawn_override_ltx + dev_cli_set_zone_* + set_zone_spawn/set_zone_center/set_zone_radius are grouped later
-- after safe_zone_restrictor_callbacks_pending (search: "Dev CLI: persist").
-- ═════════════════════════════════════════════════════════════════════════════

-- Read em_spawn_overrides.ltx from the saves folder and apply any recognised
-- fields (x/y/z center, respawn_x/y/z/dir) to the in-memory SAFE_ZONES_BY_NAME entries.
-- Called at the end of load_config() so overrides layer on top of the LTX.
load_spawn_overrides = function()
    local path = get_overrides_path()
    local f = io.open(path, "r")
    if not f then return end  -- no overrides yet; normal on first run

    local current_section = nil
    local updates = 0
    for line in f:lines() do
        -- Strip ; comments and trim surrounding whitespace.
        line = line:gsub(";.*$", ""):match("^%s*(.-)%s*$")
        if line ~= "" then
            local section = line:match("^%[(.-)%]$")
            if section then
                current_section = section
            elseif current_section then
                -- Match key = <signed float/int>
                local key, val = line:match("^([%w_]+)%s*=%s*([%-%.%d]+)")
                if key and val then
                    local zone = SAFE_ZONES_BY_NAME[current_section]
                    if zone then
                        zone[key] = tonumber(val)
                        if key == "x" or key == "y" or key == "z" then
                            zone._center_overridden = true -- dev_cli_set_zone_center / center lines
                        elseif key == "radius" then
                            zone._radius_overridden = true -- dev_cli_set_zone_radius
                        else
                            zone._overridden = true -- respawn_* / respawn_dir (dev_cli_set_zone_respawn) or other keys
                        end
                        updates = updates + 1
                        debug_log("load_spawn_overrides: zone '%s' %s = %s", current_section, key, val)
                    else
                        debug_log("load_spawn_overrides: zone '%s' not in SAFE_ZONES_BY_NAME -- skipping", current_section)
                    end
                end
            end
        end
    end
    f:close()
    debug_log("load_spawn_overrides: applied %d field(s) from %s", updates, path)
end

local function on_actor_entered_safe_zone_restrictor(zone_obj, entering_obj)
    if not (db.actor and entering_obj and entering_obj:id() == db.actor:id()) then
        return
    end
    local rid = zone_obj:id()
    ACTOR_INSIDE_SAFE_ZONE_IDS[rid] = true
    local z = SAFE_ZONES_BY_RESTRICTOR_ID[rid]
    local zname = z and z.name or "?"
    debug_log("safe_zone restrictor enter: id=%s zone=%s level=%s",
        tostring(rid), tostring(zname), level.name())
end

local function on_actor_left_safe_zone_restrictor(zone_obj, leaving_obj)
    if not (db.actor and leaving_obj and leaving_obj:id() == db.actor:id()) then
        return
    end
    local rid = zone_obj:id()
    ACTOR_INSIDE_SAFE_ZONE_IDS[rid] = nil
    local z = SAFE_ZONES_BY_RESTRICTOR_ID[rid]
    local zname = z and z.name or "?"
    debug_log("safe_zone restrictor exit: id=%s zone=%s level=%s",
        tostring(rid), tostring(zname), level.name())
end

-- One-shot sphere check after spawning/reload: if the actor is already inside the
-- configured radius, mark membership before zone_enter callbacks have a chance to fire.
local function seed_safe_zone_membership_if_already_inside_sphere()
    if not (db.actor and db.actor:alive()) then return end
    local actor_pos = db.actor:position()
    local zones = SAFE_ZONES[level.name()] or {}
    for _, z in ipairs(zones) do
        if z.restrictor_id and not SAFE_ZONE_RESTRICTOR_SEED_DONE[z.restrictor_id] then
            local zone_pos = vector():set(z.x, z.y, z.z)
            if actor_pos:distance_to_sqr(zone_pos) <= (z.radius * z.radius) then
                ACTOR_INSIDE_SAFE_ZONE_IDS[z.restrictor_id] = true
            end
            SAFE_ZONE_RESTRICTOR_SEED_DONE[z.restrictor_id] = true
        end
    end
end

local function attach_safe_zone_restrictor_callbacks()
    for restrictor_id, _ in pairs(SAFE_ZONES_BY_RESTRICTOR_ID) do
        if not SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE[restrictor_id] then
            local obj = level.object_by_id(restrictor_id)
            if obj then
                obj:set_callback(callback.zone_enter, on_actor_entered_safe_zone_restrictor)
                obj:set_callback(callback.zone_exit, on_actor_left_safe_zone_restrictor)
                SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE[restrictor_id] = true
            end
        end
    end
end

local function spawn_safe_zone_restrictor(zone)
    if not (db.actor and db.actor:alive()) then
        return nil
    end
    local pos = vector():set(zone.x, zone.y, zone.z)
    local lvid = level.vertex_id(pos)
    local gvid = db.actor:game_vertex_id()
    -- LTX section name for alife():create (spawn profile). `space_restrictor` is
    -- the base game's built-in restrictor spawn type: a server-side volume object
    -- (bind_restrictor) used for triggers and spatial tests. Defined under
    -- [space_restrictor] in configs/system.ltx. Optional key zone_section in
    -- extraction_mod_zones.ltx overrides this if you use another restrictor-derived section.
    local section = zone.zone_section or DEFAULT_ZONE_SECTION
    local se_obj = alife():create(section, pos, lvid, gvid)
    if not se_obj then
        printe("![EM] spawn_safe_zone_restrictor: failed for zone '%s' (section=%s)", zone.name, section)
        return nil
    end

    local shape_data = utils_stpk.get_space_restrictor_data(se_obj)
    if shape_data then
        shape_data.shapes = shape_data.shapes or {}
        shape_data.shapes[1] = shape_data.shapes[1] or {}
        shape_data.shapes[1].shtype = 0
        shape_data.shapes[1].offset = vector():set(0, 0, 0)
        shape_data.shapes[1].radius = zone.radius
        utils_stpk.set_space_restrictor_data(shape_data, se_obj)
    end
    local rid = se_obj.id
    debug_log("safe_zone restrictor spawned: id=%s zone=%s level=%s section=%s",
        tostring(rid), tostring(zone.name), level.name(), tostring(section))
    return rid
end

-- Clears Lua-side tracking for spawned space restrictors (membership + callbacks + id
-- maps). Does not clear data.safe_zone_restrictor_ids during normal rebuilds; those
-- persist in save data and are validated by ensure_safe_zone_restrictors_for_level().
local function clear_safe_zone_restrictor_state()
    SAFE_ZONES_BY_RESTRICTOR_ID = {}
    ACTOR_INSIDE_SAFE_ZONE_IDS = {}
    SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE = {}
    SAFE_ZONE_RESTRICTOR_SEED_DONE = {}
    for _, zones in pairs(SAFE_ZONES) do
        for _, z in ipairs(zones) do
            z.restrictor_id = nil
        end
    end
end

-- Create missing space restrictors for the current level and refresh id maps.
-- Intentionally does not attach callbacks (objects may not be online yet).
local function ensure_safe_zone_restrictors_for_level()
    if not (db.actor and db.actor:alive()) then return end
    clear_safe_zone_restrictor_state()
    local level_name = level.name()
    local zones = SAFE_ZONES[level_name] or {}
    debug_log("ensure_safe_zone_restrictors_for_level: level=%s configured_zones=%d",
        tostring(level_name), #zones)

    local function server_restrictor_section_name(id)
        local se = alife_object(id)
        if not se or type(se.section_name) ~= "function" then
            return nil
        end
        local ok, section = pcall(function() return se:section_name() end)
        if ok then return section end
        return nil
    end

    local function apply_zone_properties_to_restrictor(id, zone)
        local se = alife_object(id)
        if not se then return false end

        -- Position and graph placement.
        local pos = vector():set(zone.x, zone.y, zone.z)
        se.position = pos
        se.m_level_vertex_id = level.vertex_id(pos)
        se.m_game_vertex_id = db.actor:game_vertex_id()

        -- Runtime sphere shape (radius) from config.
        local shape_data = utils_stpk.get_space_restrictor_data(se)
        if shape_data then
            shape_data.shapes = shape_data.shapes or {}
            shape_data.shapes[1] = shape_data.shapes[1] or {}
            shape_data.shapes[1].shtype = 0
            shape_data.shapes[1].offset = vector():set(0, 0, 0)
            shape_data.shapes[1].radius = zone.radius
            utils_stpk.set_space_restrictor_data(shape_data, se)
        end
        debug_log("safe_zone restrictor apply: id=%s zone=%s pos=(%.2f,%.2f,%.2f) radius=%.2f",
            tostring(id), tostring(zone.name), zone.x, zone.y, zone.z, zone.radius)
        return true
    end

    for _, zone in ipairs(zones) do
        local restrictor_id = data.safe_zone_restrictor_ids[zone.name]
        debug_log("safe_zone restrictor resolve: zone=%s saved_id=%s section=%s",
            tostring(zone.name), tostring(restrictor_id), tostring(zone.zone_section or DEFAULT_ZONE_SECTION))
        if restrictor_id then
            local se = alife_object(restrictor_id)
            if not se then
                debug_log("safe_zone restrictor resolve: saved id missing in alife -- zone=%s id=%s",
                    tostring(zone.name), tostring(restrictor_id))
                restrictor_id = nil
                data.safe_zone_restrictor_ids[zone.name] = nil
            elseif server_restrictor_section_name(restrictor_id) ~= (zone.zone_section or DEFAULT_ZONE_SECTION) then
                debug_log("safe_zone restrictor section changed: replacing id=%s zone=%s level=%s",
                    tostring(restrictor_id), tostring(zone.name), level.name())
                alife_release_id(restrictor_id, "extraction_mod_zone_section_changed")
                restrictor_id = nil
                data.safe_zone_restrictor_ids[zone.name] = nil
            else
                debug_log("safe_zone restrictor resolve: reusing saved id=%s zone=%s",
                    tostring(restrictor_id), tostring(zone.name))
            end
        end

        if not restrictor_id then
            restrictor_id = spawn_safe_zone_restrictor(zone)
            if restrictor_id then
                data.safe_zone_restrictor_ids[zone.name] = restrictor_id
                debug_log("safe_zone restrictor resolve: spawned new id=%s zone=%s",
                    tostring(restrictor_id), tostring(zone.name))
            else
                debug_log("safe_zone restrictor resolve: spawn failed zone=%s", tostring(zone.name))
            end
        end
        if restrictor_id then
            apply_zone_properties_to_restrictor(restrictor_id, zone)
            zone.restrictor_id = restrictor_id
            SAFE_ZONES_BY_RESTRICTOR_ID[restrictor_id] = zone
            debug_log("safe_zone restrictor map: zone=%s -> id=%s", tostring(zone.name), tostring(restrictor_id))
        else
            debug_log("safe_zone restrictor map: zone=%s unresolved (no id)", tostring(zone.name))
        end
    end

    seed_safe_zone_membership_if_already_inside_sphere()
    debug_log("ensure_safe_zone_restrictors_for_level: completed level=%s mapped_ids=%d", tostring(level_name), (function()
        local n = 0
        for _ in pairs(SAFE_ZONES_BY_RESTRICTOR_ID) do n = n + 1 end
        return n
    end)())
end

-- Try to attach zone_enter/zone_exit callbacks; safe to call repeatedly until all ids bind.
local function refresh_safe_zone_restrictor_callbacks()
    attach_safe_zone_restrictor_callbacks()
    seed_safe_zone_membership_if_already_inside_sphere()
end

local function safe_zone_restrictor_callbacks_pending()
    for restrictor_id, _ in pairs(SAFE_ZONES_BY_RESTRICTOR_ID) do
        if not SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE[restrictor_id] then
            return true
        end
    end
    return false
end

-- ─── Dev CLI: persist + commands (see DEVELOPER CLI TOOLS header above) ───

-- Remove the session's spawned restrictor for one zone so it can be recreated at a
-- new center or radius (dev_cli_set_zone_center / dev_cli_set_zone_radius). Clears
-- data.safe_zone_restrictor_ids only; full maps are rebuilt by ensure_safe_zone_restrictors_for_level().
local function release_session_safe_zone_restrictor_for_zone_name(zone_name)
    local id = data.safe_zone_restrictor_ids[zone_name]
    if id and alife_object(id) then
        alife_release_id(id, "extraction_mod_dev_cli_restrictor_rebuild")
    end
    data.safe_zone_restrictor_ids[zone_name] = nil
end

-- Write dev overrides to em_spawn_overrides.ltx: center x/y/z (dev_cli_set_zone_center),
-- radius (dev_cli_set_zone_radius), and/or respawn_x/y/z/dir (dev_cli_set_zone_respawn).
-- Returns true on success, false on IO failure.
local function write_spawn_override_ltx()
    local path = get_overrides_path()
    local f = io.open(path, "w")
    if not f then
        printe("![EM] write_spawn_override_ltx: cannot open '%s' for writing", path)
        return false
    end
    f:write("; em_spawn_overrides.ltx -- written by extraction_mod dev_cli_set_zone_respawn / center / radius\n")
    f:write("; copy section contents to extraction_mod_zones.ltx to make permanent\n\n")
    for name, z in pairs(SAFE_ZONES_BY_NAME) do
        if z._overridden or z._center_overridden or z._radius_overridden then
            f:write("[" .. name .. "]\n")
            if z._center_overridden then
                f:write(string.format("x = %.4f\n", z.x))
                f:write(string.format("y = %.4f\n", z.y))
                f:write(string.format("z = %.4f\n", z.z))
            end
            if z._radius_overridden then
                f:write(string.format("radius = %.4f\n", z.radius))
            end
            if z._overridden then
                f:write(string.format("respawn_x   = %.4f\n", z.respawn_x))
                f:write(string.format("respawn_y   = %.4f\n", z.respawn_y))
                f:write(string.format("respawn_z   = %.4f\n", z.respawn_z))
                if z.respawn_dir then
                    f:write(string.format("respawn_dir = %.4f\n", z.respawn_dir))
                end
            end
            f:write("\n")
        end
    end
    f:close()
    return true
end

-- Copy actor position and facing into the zone's respawn_* fields, refresh
-- last-base graph data, and write em_spawn_overrides.ltx. Shared by dev CLI
-- and the MCM base hotkey.
local function apply_zone_respawn_from_actor(zone)
    if not (db.actor and db.actor:alive() and zone) then
        return false
    end
    local pos = db.actor:position()
    local dir = -db.actor:direction():getH()
    zone.respawn_x   = pos.x
    zone.respawn_y   = pos.y
    zone.respawn_z   = pos.z
    zone.respawn_dir = dir
    zone._overridden = true
    record_respawn_base_from_zone(zone)
    return write_spawn_override_ltx()
end

-- Capture respawn_x/y/z and respawn_dir from the actor (CLI dev tool).
function dev_cli_set_zone_respawn(zone_name)
    if not (db.actor and db.actor:alive()) then
        printf("[EM] dev_cli_set_zone_respawn: actor not available")
        flush()
        return
    end

    local zone
    if zone_name then
        zone = SAFE_ZONES_BY_NAME[zone_name]
        if not zone then
            printf("[EM] dev_cli_set_zone_respawn: zone '%s' not found. Available zones:", tostring(zone_name))
            for name, _ in pairs(SAFE_ZONES_BY_NAME) do
                printf("[EM]   %s", name)
            end
            flush()
            return
        end
    else
        zone = get_friendly_safe_zone_actor_is_inside()
        if not zone then
            printf("[EM] dev_cli_set_zone_respawn: not currently inside any safe zone.")
            printf("[EM] Move into a zone or pass the zone name explicitly:")
            printf("[EM]   run_string extraction_mod.dev_cli_set_zone_respawn(\"zone_name\")")
            flush()
            return
        end
        zone_name = zone.name
    end

    local saved = apply_zone_respawn_from_actor(zone)

    printf("[EM] dev_cli_set_zone_respawn: zone '%s' respawn updated (configured level=%s, you are on %s)",
        zone_name, tostring(zone.level), level.name())
    printf("[EM]   respawn_x   = %s", string.format("%.4f", zone.respawn_x))
    printf("[EM]   respawn_y   = %s", string.format("%.4f", zone.respawn_y))
    printf("[EM]   respawn_z   = %s", string.format("%.4f", zone.respawn_z))
    printf("[EM]   respawn_dir = %s", string.format("%.4f", zone.respawn_dir or 0))
    if zone.level ~= level.name() then
        printf("[EM] Respawn override is saved; it applies on death / when you play that zone.")
    end
    if saved then
        printf("[EM] Written to: %s", get_overrides_path())
        printf("[EM] To make permanent, copy the [%s] section from that file", zone_name)
        printf("[EM] into extraction_mod_zones.ltx.")
    end
    flush()
end

-- Capture zone center x/y/z from the actor (CLI dev tool). Recreates the restrictor on this map.
function dev_cli_set_zone_center(zone_name)
    if not (db.actor and db.actor:alive()) then
        printf("[EM] dev_cli_set_zone_center: actor not available")
        flush()
        return
    end

    local zone
    if zone_name then
        zone = SAFE_ZONES_BY_NAME[zone_name]
        if not zone then
            printf("[EM] dev_cli_set_zone_center: zone '%s' not found. Available zones:", tostring(zone_name))
            for name, _ in pairs(SAFE_ZONES_BY_NAME) do
                printf("[EM]   %s", name)
            end
            flush()
            return
        end
    else
        zone = get_friendly_safe_zone_actor_is_inside()
        if not zone then
            printf("[EM] dev_cli_set_zone_center: not currently inside any safe zone.")
            printf("[EM] Move into a zone or pass the zone name explicitly:")
            printf("[EM]   run_string extraction_mod.dev_cli_set_zone_center(\"zone_name\")")
            flush()
            return
        end
        zone_name = zone.name
    end

    local pos = db.actor:position()
    zone.x = pos.x
    zone.y = pos.y
    zone.z = pos.z
    zone._center_overridden = true

    local saved = write_spawn_override_ltx()

    if zone.level == level.name() then
        release_session_safe_zone_restrictor_for_zone_name(zone_name)
        ensure_safe_zone_restrictors_for_level()
        refresh_safe_zone_restrictor_callbacks()
    end

    printf("[EM] dev_cli_set_zone_center: zone '%s' center updated (configured level=%s, you are on %s)",
        zone_name, tostring(zone.level), level.name())
    printf("[EM]   x = %s", string.format("%.4f", pos.x))
    printf("[EM]   y = %s", string.format("%.4f", pos.y))
    printf("[EM]   z = %s", string.format("%.4f", pos.z))
    if zone.level ~= level.name() then
        printf("[EM] Restrictor is recreated when you load that zone; overrides file is still updated.")
    end
    if saved then
        printf("[EM] Written to: %s", get_overrides_path())
        printf("[EM] To make permanent, copy the [%s] section from that file", zone_name)
        printf("[EM] into extraction_mod_zones.ltx.")
    end
    flush()
end

-- Set zone.radius to the 3D distance from the configured zone center to the actor (CLI).
-- Stand on the desired sphere boundary (or anywhere inside/outside with a named zone);
-- radius is max(distance, 1) metres so the value is always usable. Recreates the
-- restrictor on this map when the zone belongs to the current level.
function dev_cli_set_zone_radius(zone_name)
    if not (db.actor and db.actor:alive()) then
        printf("[EM] dev_cli_set_zone_radius: actor not available")
        flush()
        return
    end

    local zone
    if zone_name then
        zone = SAFE_ZONES_BY_NAME[zone_name]
        if not zone then
            printf("[EM] dev_cli_set_zone_radius: zone '%s' not found. Available zones:", tostring(zone_name))
            for name, _ in pairs(SAFE_ZONES_BY_NAME) do
                printf("[EM]   %s", name)
            end
            flush()
            return
        end
    else
        zone = get_friendly_safe_zone_actor_is_inside()
        if not zone then
            printf("[EM] dev_cli_set_zone_radius: not currently inside any safe zone.")
            printf("[EM] Move into a zone or pass the zone name explicitly:")
            printf("[EM]   run_string extraction_mod.dev_cli_set_zone_radius(\"zone_name\")")
            flush()
            return
        end
        zone_name = zone.name
    end

    local MIN_RADIUS_METRES = 1.0
    local center = vector():set(zone.x, zone.y, zone.z)
    local ap = db.actor:position()
    local dist = math.sqrt(ap:distance_to_sqr(center))
    local r = math.max(dist, MIN_RADIUS_METRES)
    zone.radius = r
    zone._radius_overridden = true

    local saved = write_spawn_override_ltx()

    if zone.level == level.name() then
        release_session_safe_zone_restrictor_for_zone_name(zone_name)
        ensure_safe_zone_restrictors_for_level()
        refresh_safe_zone_restrictor_callbacks()
    end

    printf("[EM] dev_cli_set_zone_radius: zone '%s' radius set from actor distance (configured level=%s, you are on %s)",
        zone_name, tostring(zone.level), level.name())
    printf("[EM]   center=(%s, %s, %s)", string.format("%.4f", zone.x), string.format("%.4f", zone.y), string.format("%.4f", zone.z))
    printf("[EM]   actor distance = %s  ->  radius = %s (min %s)",
        string.format("%.4f", dist), string.format("%.4f", r), string.format("%.1f", MIN_RADIUS_METRES))
    if zone.level ~= level.name() then
        printf("[EM] Restrictor is recreated when you load that zone; overrides file is still updated.")
    end
    if saved then
        printf("[EM] Written to: %s", get_overrides_path())
        printf("[EM] To make permanent, copy the [%s] section from that file", zone_name)
        printf("[EM] into extraction_mod_zones.ltx.")
    end
    flush()
end

-- Shorter CLI-friendly names (same as dev_cli_*). Thin wrappers so these behave like
-- normal global functions if the loader only binds `function` decls.
function set_zone_spawn(zone_name)
    dev_cli_set_zone_respawn(zone_name)
end

function set_zone_center(zone_name)
    dev_cli_set_zone_center(zone_name)
end

function set_zone_radius(zone_name)
    dev_cli_set_zone_radius(zone_name)
end

-- In-game hour captured at the moment actor_on_before_death fires.
-- level.get_time_hours() can return a stale/reset value by the time
-- complete_extraction_respawn runs ~3 seconds later (the engine appears to restore
-- save-file time as part of processing the cancelled death). Caching here
-- gives us the definitive time-of-death for the night-respawn check.
local death_hour = nil

-- Formatted in-game date/time string captured at the moment of death, e.g.
-- "Death: 14.04.2012 21:33". Used as the PDA stash marker label.
-- Captured alongside death_hour using CTime:get() to avoid the same stale-time
-- problem (game.get_game_time() returns the restored save time by the time
-- poll_death_stash_transfer_and_queue_respawn runs). Pattern: utils_data.CTime_to_table().
local death_label = nil
-- Snapshot of the configured death-item handling mode at the time of death.
-- Used by deferred respawn messaging so it reflects what actually happened.
local delete_items_on_death_pending = false

-- Trigger a save to our fixed file.
-- [GAP-1] exec_console_cmd undocumented; confirmed by Jabbers Soulslike source.
local function save_extraction_slot()
    debug_log("save_extraction_slot: writing %s (level=%s)", SAVE_FILENAME, level.name())
    save_in_progress = true
    exec_console_cmd("save " .. SAVE_FILENAME)
    -- exec_console_cmd fires on_console_execute synchronously (SendScriptCallback
    -- in _g.script is synchronous), so by the time we reach this line the
    -- on_console_execute handler has already seen save_in_progress == true and
    -- returned without any recursion.
    save_in_progress = false
end

-- MCM-configurable hotkey: in a safe zone, set the active respawn BASE
-- (record_respawn_base_from_zone only). This hotkey never triggers a save and
-- does not write respawn_* overrides.
local function extraction_mod_on_key_press(key)
    local dik = mcm_base_hotkey_dik()
    if not dik or key ~= dik then return end
    if not (db.actor and db.actor:alive()) then return end
    if not actor_menu.is_hud_free() then return end
    if db.actor:is_talking() then return end

    local zone = get_friendly_safe_zone_actor_is_inside()
    if not zone then
        show_msg("Base hotkey: enter a safe zone to set that zone as respawn.")
        return
    end

    record_respawn_base_from_zone(zone)
    show_msg("Respawn base updated.")
end

-- Build a stable list of inventory items to process on death.
-- Any item section in keep_on_death is excluded.
local function collect_actor_inventory_excluding_keep_on_death()
    local items = {}
    db.actor:iterate_inventory(function(_, obj)
        if not keep_on_death[obj:section()] then
            items[#items + 1] = obj
        end
    end, nil)
    return items
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Save & load state
-- ─────────────────────────────────────────────────────────────────────────────

-- Bytes of `SAVE_FILENAME.scop` read for a cheap on-disk fingerprint (size +
-- rolling hash of prefix). Used to detect an external overwrite of our fixed
-- slot when the filename stays SAVE_FILENAME (e.g. C++ console `save em_extraction_save`).
local SLOTFPRINT_READ = 8192

local function read_mod_save_slot_disk_fingerprint()
    local path = getFS():update_path("$game_saves$", "") .. SAVE_FILENAME .. ".scop"
    local fh   = io.open(path, "rb")
    if not fh then return nil end
    local sz = fh:seek("end")
    fh:seek("set", 0)
    local chunk = fh:read(SLOTFPRINT_READ) or ""
    fh:close()
    local sig = #chunk
    for i = 1, #chunk do
        sig = (sig * 131 + string.byte(chunk, i)) % 2147483647
    end
    return { size = sz, sig = sig }
end

local function mod_save_disk_fingerprints_differ(before, after)
    if before == nil and after == nil then return false end
    if before == nil or after == nil then return true end
    return before.size ~= after.size or before.sig ~= after.sig
end

-- Copy companion save files (.scop / .scoc / .dds) between stems. Returns
-- true if a .scop was copied (confirms a readable slot existed on disk).
local function copy_save_slot_extensions_between_stems(src_stem, dst_stem)
    local base = getFS():update_path("$game_saves$", "")
    local copied_scop = false
    for _, ext in ipairs({ ".scop", ".scoc", ".dds" }) do
        local src_path = base .. src_stem .. ext
        local dst_path = base .. dst_stem .. ext
        local ri       = io.open(src_path, "rb")
        if ri then
            local bytes = ri:read("*a")
            ri:close()
            local wo = io.open(dst_path, "wb")
            if wo then
                wo:write(bytes or "")
                wo:close()
                if ext == ".scop" then copied_scop = true end
            else
                debug_log("copy_save_slot_extensions_between_stems: failed to write '%s'", dst_path)
            end
        end
    end
    return copied_scop
end

local function migrate_all_existing_saves_to_first_run_backup()
    local fs = getFS()
    if not fs then return false end
    local base = getFS():update_path("$game_saves$", "")
    local backup_dir = FIRST_RUN_BACKUP_DIR_PREFIX .. os.date("%Y%m%d_%H%M%S")

    local flist = fs:file_list_open_ex(
        "$game_saves$",
        bit_or(FS.FS_ListFiles, FS.FS_RootOnly),
        "*.scop"
    )
    local n = flist:Size()
    debug_log("first-run migration: found %d save slot(s), backup_dir=%s", n, backup_dir)
    local moved = 0
    local failed = 0
    for i = 0, n - 1 do
        local file      = flist:GetAt(i)
        local fullname  = file:NameFull()
        local stem = fullname:match("^(.+)%.scop$") or fullname
        local moved_scop = false
        local move_failed = false
        for _, ext in ipairs({ ".scop", ".scoc", ".dds" }) do
            local src_path = base .. stem .. ext
            local ri = io.open(src_path, "rb")
            if ri then
                ri:close()
                local dst_path = base .. backup_dir .. "/" .. stem .. ext
                local moved = false
                if fs.file_rename then
                    local ok = pcall(function()
                        fs:file_rename(src_path, dst_path, true)
                    end)
                    if ok then
                        local src_chk = io.open(src_path, "rb")
                        local dst_chk = io.open(dst_path, "rb")
                        if src_chk then src_chk:close() end
                        if dst_chk then dst_chk:close() end
                        moved = (dst_chk ~= nil and src_chk == nil)
                    end
                end
                if moved then
                    if ext == ".scop" then moved_scop = true end
                else
                    move_failed = true
                    printe("![EM] first-run migration: move failed '%s' -> '%s'", src_path, dst_path)
                end
            end
        end
        if moved_scop and not move_failed then
            moved = moved + 1
            debug_log("first-run migration: moved save '%s' to '%s/%s'", stem, backup_dir, stem)
        else
            failed = failed + 1
            debug_log("first-run migration: move incomplete for '%s' (moved_scop=%s move_failed=%s)",
                stem, tostring(moved_scop), tostring(move_failed))
        end
    end
    debug_log("first-run migration: done moved=%d failed=%d backup_dir=%s", moved, failed, backup_dir)
    return failed == 0
end

-- Scan the saves folder for any .scop file that is not our fixed save and
-- delete it. Called with a short delay after save_state detects an external
-- save, giving the engine time to finish writing the file to disk first.
-- Pattern for file_list_open_ex confirmed from ui_load_dialog.script.
-- NOTE: flist:GetAt(i) returns a file object (userdata), NOT a plain string.
-- Call :NameFull() to get the filename string (confirmed from FillList in
-- ui_load_dialog.script which does the same).
local function enforce_single_mod_save_slot()
    local ctx = external_save_cleanup_ctx
    external_save_cleanup_ctx = nil

    local flist = getFS():file_list_open_ex(
        "$game_saves$",
        bit_or(FS.FS_ListFiles, FS.FS_RootOnly),
        "*.scop"
    )
    local n = flist:Size()
    debug_log("enforce_single_mod_save_slot: scanning %s .scop files", n)
    for i = 0, n - 1 do
        local file      = flist:GetAt(i)
        local fullname  = file:NameFull()   -- e.g. "player - quicksave.scop"
        -- Strip .scop extension to get the name delete_save_game expects.
        local save_name = fullname:match("^(.+)%.scop$") or fullname
        if save_name ~= SAVE_FILENAME then
            debug_log("enforce_single_mod_save_slot: deleting unauthorized save '%s'", save_name)
            ui_load_dialog.delete_save_game(save_name)
        end
    end

    -- Same stem as SAVE_FILENAME but written outside a base (C++ console, etc.).
    -- The loop above keeps that file; if the slot changed and we have a guard
    -- snapshot from save_state, restore it so the last legal base save is not lost.
    if ctx and not ctx.in_safe then
        local after  = read_mod_save_slot_disk_fingerprint()
        local changed = mod_save_disk_fingerprints_differ(ctx.slot_fp_before, after)
        if ctx.slot_guard_written and not changed then
            debug_log("enforce_single_mod_save_slot: discarding unused slot guard (slot untouched)")
            ui_load_dialog.delete_save_game(SLOT_GUARD_STEM)
        elseif changed then
            if ctx.slot_guard_written then
                debug_log("enforce_single_mod_save_slot: restoring '%s' from guard after illegal overwrite",
                    SAVE_FILENAME)
                copy_save_slot_extensions_between_stems(SLOT_GUARD_STEM, SAVE_FILENAME)
                ui_load_dialog.delete_save_game(SLOT_GUARD_STEM)
                show_msg("Cannot save outside a friendly base! Your last base save was restored.")
            else
                debug_log("enforce_single_mod_save_slot: illegal write to empty slot -- deleting '%s'",
                    SAVE_FILENAME)
                ui_load_dialog.delete_save_game(SAVE_FILENAME)
                show_msg("Cannot save outside a friendly base! Save was not kept.")
            end
        end
    end

    return true
end

local function save_state(m_data)
    local safe_zone_ids_to_save = 0
    for _ in pairs(data.safe_zone_restrictor_ids) do
        safe_zone_ids_to_save = safe_zone_ids_to_save + 1
    end
    m_data[MOD_KEY] = {
        last_base_name  = data.last_base_name,
        last_base_level = data.last_base_level,
        last_base_lvid  = data.last_base_lvid,
        last_base_gvid  = data.last_base_gvid,
        stash_ids       = data.stash_ids,
        death_stash_ids = data.death_stash_ids,
        pending_stash_release_ids = data.pending_stash_release_ids,
        last_stash_loot_game_ms = data.last_stash_loot_game_ms,
        safe_zone_restrictor_ids = data.safe_zone_restrictor_ids,
        tainted_by_forbidden_load = data.tainted_by_forbidden_load,
        first_run_migration_done = data.first_run_migration_done,
    }
    debug_log("save_state: base=%s level=%s safe_zone_ids=%d",
        tostring(data.last_base_name), tostring(data.last_base_level), safe_zone_ids_to_save)
    for zone_name, rid in pairs(data.safe_zone_restrictor_ids) do
        debug_log("save_state: safe_zone_id[%s]=%s", tostring(zone_name), tostring(rid))
    end

    -- on_console_execute only fires when saves are triggered through Lua's
    -- exec_console_cmd wrapper. Saves typed directly into the C++ console
    -- bypass it entirely. save_state fires for ALL saves (C++ calls it), so
    -- we use it as a catch-all: if save_in_progress is false this is an
    -- external save we didn't initiate, so schedule a scan to remove any
    -- unauthorized files after the engine finishes writing them.
    if suppress_external_save_cleanup_once then
        suppress_external_save_cleanup_once = false
        debug_log("save_state: skipping one external cleanup pass (first-run forced save)")
        return
    end
    if not save_in_progress then
        debug_log("save_state: external save detected -- scheduling cleanup scan")
        local fp_before = read_mod_save_slot_disk_fingerprint()
        local in_safe   = get_friendly_safe_zone_actor_is_inside() ~= nil
        -- While this callback runs the old .scop is still on disk; copy it before
        -- the engine can overwrite with an illegal `save em_extraction_save`.
        local guard_written = false
        if not in_safe and fp_before ~= nil then
            ui_load_dialog.delete_save_game(SLOT_GUARD_STEM)
            guard_written = copy_save_slot_extensions_between_stems(SAVE_FILENAME, SLOT_GUARD_STEM)
            if not guard_written then
                debug_log("save_state: guard copy failed (no .scop to read?)")
            end
        end
        external_save_cleanup_ctx = {
            slot_fp_before      = fp_before,
            in_safe             = in_safe,
            slot_guard_written  = guard_written,
        }
        CreateTimeEvent("extraction_mod", "save_cleanup", 1, enforce_single_mod_save_slot)
    end
end

local function load_state(m_data)
    load_state_seen_this_session = true
    local saved          = m_data[MOD_KEY] or {}
    data.last_base_name  = saved.last_base_name
    data.last_base_level = saved.last_base_level
    data.last_base_lvid  = saved.last_base_lvid
    data.last_base_gvid  = saved.last_base_gvid
    data.stash_ids       = saved.stash_ids or {}
    data.death_stash_ids = saved.death_stash_ids or {}
    data.pending_stash_release_ids = saved.pending_stash_release_ids or {}
    data.safe_zone_restrictor_ids = {}
    data.tainted_by_forbidden_load = saved.tainted_by_forbidden_load == true
    data.first_run_migration_done = saved.first_run_migration_done == true
    local restored = 0
    local dropped = 0
    local incoming = 0
    if type(saved.safe_zone_restrictor_ids) == "table" then
        for zone_name, rid in pairs(saved.safe_zone_restrictor_ids) do
            incoming = incoming + 1
            local rid_num = tonumber(rid)
            if SAFE_ZONES_BY_NAME[zone_name] and rid_num then
                data.safe_zone_restrictor_ids[zone_name] = rid_num
                restored = restored + 1
                debug_log("load_state: restored safe_zone_id[%s]=%s", tostring(zone_name), tostring(rid_num))
            else
                dropped = dropped + 1
                debug_log("load_state: dropped invalid safe_zone_id[%s]=%s (zone_exists=%s)",
                    tostring(zone_name), tostring(rid), tostring(SAFE_ZONES_BY_NAME[zone_name] ~= nil))
            end
        end
    end
    -- Older saves only persisted stash_ids (marked stashes). Treat them as death
    -- stashes so loot simulation and empty cleanup still apply after upgrade.
    for sid, _ in pairs(data.stash_ids) do
        data.death_stash_ids[sid] = true
    end
    data.last_stash_loot_game_ms = saved.last_stash_loot_game_ms
    if data.tainted_by_forbidden_load then
        next_taint_warning_ms = game.time()
    end
    debug_log("load_state: base=%s level=%s safe_zone_ids incoming=%d restored=%d dropped=%d",
        tostring(data.last_base_name), tostring(data.last_base_level), incoming, restored, dropped)
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Death stash NPC loot simulation (optional)
-- Randomly removes items from prior death stashes on an in-game-time cadence.
-- Empty stashes are released and PDA markers cleared. If a stash is currently
-- online, release is deferred until it goes offline to avoid UI-time crashes.
-- HARD INVARIANT:
--   Never call alife_release_id on stash items OR the stash container while that
--   stash is online (level.object_by_id(stash_id) ~= nil).
--   Online stashes are skipped/deferred and processed only after they go offline.
-- Uses alife():get_children + alife_release_id (works for online/offline stashes).
-- ─────────────────────────────────────────────────────────────────────────────

-- alife():get_children(se) yields each child's alife id as a **number** in Anomaly
-- (not a table with .id). Accept both so offline inventory collection stays safe.
local function alife_child_id(entry)
    if type(entry) == "number" then return entry end
    if type(entry) == "table" and entry.id then return entry.id end
    return nil
end

local function death_stash_item_count(stash_id)
    local se = alife_object(stash_id)
    if not se then return 0 end
    local n = 0
    for _ in alife():get_children(se) do
        n = n + 1
    end
    return n
end

local function death_stash_collect_item_ids(stash_id)
    local ids = {}
    local se = alife_object(stash_id)
    if se then
        for child in alife():get_children(se) do
            local cid = alife_child_id(child)
            if cid then ids[#ids + 1] = cid end
        end
    end
    return ids
end

local function clear_stash_pda_marker(stash_id)
    if data.stash_ids[stash_id] then
        level.map_remove_object_spot(stash_id, "secondary_task_location")
        data.stash_ids[stash_id] = nil
        debug_log("clear_stash_pda_marker: removed PDA spot for id=%d", stash_id)
    end
end

local function remove_empty_death_stash(stash_id, reason)
    if not data.death_stash_ids[stash_id] then return false end
    if death_stash_item_count(stash_id) > 0 then return false end
    if not alife_object(stash_id) then
        -- During inventory/UI teardown (player emptied stash) the engine can drop
        -- alife handle mid-frame. Defer final cleanup to periodic release pass.
        if reason == "extraction_mod_player_emptied" then
            data.pending_stash_release_ids[stash_id] = true
            debug_log("remove_empty_death_stash: id=%d missing alife during player-empty -- deferring cleanup",
                stash_id)
            return true
        end
        clear_stash_pda_marker(stash_id)
        data.death_stash_ids[stash_id] = nil
        debug_log("remove_empty_death_stash: id=%d missing alife -- cleared tracking (%s)",
            stash_id, tostring(reason))
        return true
    end
    clear_stash_pda_marker(stash_id)
    if level.object_by_id(stash_id) then
        data.pending_stash_release_ids[stash_id] = true
        debug_log("remove_empty_death_stash: id=%d empty but ONLINE -- deferring release (%s)",
            stash_id, tostring(reason))
        return true
    end
    alife_release_id(stash_id, reason or "extraction_mod_stash_empty")
    data.death_stash_ids[stash_id] = nil
    data.pending_stash_release_ids[stash_id] = nil
    debug_log("remove_empty_death_stash: released empty stash id=%d (%s)", stash_id, tostring(reason))
    return true
end

local function release_pending_empty_death_stashes()
    for stash_id, _ in pairs(data.pending_stash_release_ids) do
        if not data.death_stash_ids[stash_id] then
            data.pending_stash_release_ids[stash_id] = nil
        elseif level.object_by_id(stash_id) then
            -- Still online/open. Keep waiting.
        elseif not alife_object(stash_id) then
            data.pending_stash_release_ids[stash_id] = nil
            data.death_stash_ids[stash_id] = nil
            clear_stash_pda_marker(stash_id)
            debug_log("release_pending_empty_death_stashes: id=%d missing alife -- dropped tracking", stash_id)
        elseif death_stash_item_count(stash_id) > 0 then
            -- Became non-empty again somehow (e.g. script added an item). Cancel.
            data.pending_stash_release_ids[stash_id] = nil
            debug_log("release_pending_empty_death_stashes: id=%d no longer empty -- canceled defer", stash_id)
        else
            clear_stash_pda_marker(stash_id)
            alife_release_id(stash_id, "extraction_mod_stash_empty_deferred")
            data.pending_stash_release_ids[stash_id] = nil
            data.death_stash_ids[stash_id] = nil
            debug_log("release_pending_empty_death_stashes: released deferred empty stash id=%d", stash_id)
        end
    end
end

local function tick_pending_death_stash_releases()
    if db.actor and db.actor:alive() then
        release_pending_empty_death_stashes()
    end
    return false -- keep polling via CreateTimeEvent
end

local function remove_random_item_from_death_stash(stash_id, reason)
    if not data.death_stash_ids[stash_id] then return end
    -- Never release child items while the container is online. Releasing alife
    -- children of an online stash can trigger engine-side destroy-order errors.
    -- Keep this stash untouched for now; a later pulse will process it offline.
    if level.object_by_id(stash_id) then
        debug_log("remove_random_item_from_death_stash: id=%d is ONLINE -- skipping pulse", stash_id)
        return
    end
    if not alife_object(stash_id) then
        clear_stash_pda_marker(stash_id)
        data.death_stash_ids[stash_id] = nil
        debug_log("remove_random_item_from_death_stash: id=%d invalid alife -- dropped tracking", stash_id)
        return
    end
    local ids = death_stash_collect_item_ids(stash_id)
    if #ids == 0 then
        remove_empty_death_stash(stash_id, reason)
        return
    end
    local pick = ids[math.random(#ids)]
    alife_release_id(pick, reason or "extraction_mod_npc_loot")
    debug_log("remove_random_item_from_death_stash: released item id=%d from stash id=%d",
        pick, stash_id)
    remove_empty_death_stash(stash_id, reason)
end

local function pulse_death_stash_npc_looting(reason)
    if not mcm_option("stash_npc_looting") then return end
    local list = {}
    for id, _ in pairs(data.death_stash_ids) do
        list[#list + 1] = id
    end
    if #list == 0 then return end
    local chance_pct = stash_loot_delete_chance_percent
    debug_log("pulse_death_stash_npc_looting: %d stash(es) reason=%s delete_chance_percent=%.2f",
        #list, tostring(reason), chance_pct)
    if chance_pct <= 0 then return end
    for _, id in ipairs(list) do
        if data.death_stash_ids[id] then
            -- Roll per stash so each one is evaluated independently this pulse.
            local roll_pct = math.random() * 100
            if roll_pct < chance_pct then
                remove_random_item_from_death_stash(id, reason)
            else
                debug_log("pulse_death_stash_npc_looting: stash id=%d skipped (roll=%.2f >= %.2f)",
                    id, roll_pct, chance_pct)
            end
        end
    end
end

local function tick_death_stash_npc_loot_by_game_time()
    local hours = stash_loot_interval_hours_resolved()
    if not mcm_option("stash_npc_looting") or hours <= 0 then return end
    if not (db.actor and db.actor:alive()) then return end
    -- game.time() = in-game ms since epoch (game.md). Do not use CTime() here:
    -- the CTime constructor is not bound as a global in this script's Lua env.
    local now_ms = game.time()
    if not data.last_stash_loot_game_ms then
        data.last_stash_loot_game_ms = now_ms
        return
    end
    local need_ms = hours * 3600 * 1000
    if (now_ms - data.last_stash_loot_game_ms) < need_ms then return end
    pulse_death_stash_npc_looting("interval")
    data.last_stash_loot_game_ms = now_ms
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Periodic safe-zone tracking
-- ─────────────────────────────────────────────────────────────────────────────

local last_check_time = 0
local last_safe_zone_restrictor_bind_poll_time = 0
local was_in_safe_zone = false
local pending_release_timer_started = false
local next_taint_warning_ms = nil

local function mark_run_tainted_by_forbidden_load(reason)
    if data.tainted_by_forbidden_load then return end
    data.tainted_by_forbidden_load = true
    next_taint_warning_ms = game.time()
    debug_log("mark_run_tainted_by_forbidden_load: %s", tostring(reason))
    show_msg(CHEAT_LOAD_WATERMARK_MSG)
end

local function actor_on_update()
    if not (db.actor and db.actor:alive()) then return end

    local now = game.time()
    -- Restrictors may come online a few ticks after alife():create. Binding is cheap;
    -- establishment (spawn + shape rewrite) runs only from load_state / first update.
    if safe_zone_restrictor_callbacks_pending()
        or (now - last_safe_zone_restrictor_bind_poll_time) > 250 then
        last_safe_zone_restrictor_bind_poll_time = now
        refresh_safe_zone_restrictor_callbacks()
    end

    local zone    = get_friendly_safe_zone_actor_is_inside()
    local in_safe = zone ~= nil

    if in_safe ~= was_in_safe_zone then
        debug_log("actor_on_update: safe zone state changed -> %s (level=%s)",
            tostring(in_safe), level.name())
    end

    if in_safe and not was_in_safe_zone then
        debug_log("actor_on_update: entered base zone")
        show_msg("Safe zone: you can save here and/or set this zone as your respawn base.")
    end 
    if (not in_safe) and was_in_safe_zone then
        debug_log("actor_on_update: left base zone")
        show_msg("Left safe zone: saves are disabled until you return.")
    end
    was_in_safe_zone = in_safe

    if data.tainted_by_forbidden_load then
        -- Keep persistent punishment state for tainted runs.
        db.actor.radiation = 1
    end

    if (now - last_check_time) < UPDATE_INTERVAL then return end
    last_check_time = now

    if data.tainted_by_forbidden_load then
        if not next_taint_warning_ms or now >= next_taint_warning_ms then
            show_msg(CHEAT_LOAD_WATERMARK_MSG)
            next_taint_warning_ms = now + 15000
        end
    end

    tick_death_stash_npc_loot_by_game_time()
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Load blocking
--
-- In Extraction Mode loading a save mid-session lets the player undo bad
-- decisions (taking damage, losing a fight) without the gear-loss penalty.
-- We block ALL loads while a game session is active (db.actor alive).
-- When the player is at the main menu db.actor is nil, so loads are free.
--
-- Two paths are covered:
--
--   on_before_load_input -- F9 quickload keybind.
--     Fires from level_input.script. flags.ret = true cancels it entirely.
--
--   UILoadDialog.load_game_internal patch -- ESC menu load dialog.
--     Replaces the method on the shared class table so all dialog instances
--     go through our check. The original is saved and restored on on_game_end.
--     The patch is installed in on_game_start by forcing ui_load_dialog.script
--     to load (if it hasn't already) and then overwriting the method.
--     Main-menu loads go through the same method but db.actor is nil there,
--     so they are always allowed through.
--
-- C++ console "load" typed directly bypasses all Lua hooks and is out of scope.
-- ─────────────────────────────────────────────────────────────────────────────

-- Saved when the UILoadDialog class is patched; restored in on_game_end.
local orig_load_game_internal = nil

local function on_before_load_input(dik, bind, flags)
    -- db.actor is nil at the main menu (no session active) -- allow load.
    if not db.actor then return end
    flags.ret = true
    debug_log("on_before_load_input: BLOCKED -- session active")
    show_msg("Cannot load -- extraction mode is active!")
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Save interception  -- three layers:
--
--   Layer 1: on_before_save_input (quicksave only)
--     Cancels the quicksave before anything is written to disk.
--     Gives immediate feedback and avoids the write-then-delete cycle.
--
--   Layer 2: on_console_execute (Lua-initiated saves only)
--     Fires when exec_console_cmd runs a save. Redirects to the fixed file in
--     a safe zone; wrong filenames are removed by enforce_single_mod_save_slot.
--     C++ console saves never hit this callback.
--     on_console_execute IS documented in the callbacks reference.
--
--   Layer 3: save_state + deferred cleanup (fingerprint + optional guard copy)
--     C++ console `save em_extraction_save` bypasses Layer 2 but still runs
--     save_state. Outside a base we copy the live slot to SLOT_GUARD_STEM first;
--     after the write, cleanup restores the slot from that copy if it changed.
--
--   [GAP-3] ui_load_dialog.delete_save_game  -- not documented in guide.
--           Found in Jabbers Soulslike source. Takes lowercase filename,
--           no extension. Should be added to an API reference page.
-- ─────────────────────────────────────────────────────────────────────────────

-- Layer 1: block quicksave at the input level (no file is written).
local function on_before_save_input(flags)
    if not db.actor then return end
    local in_safe = get_friendly_safe_zone_actor_is_inside() ~= nil
    debug_log("on_before_save_input: in_safe=%s level=%s", tostring(in_safe), level.name())
    if not in_safe then
        flags.ret = true -- "ret = true" cancels per callbacks-reference docs
        debug_log("on_before_save_input: BLOCKED (not in safe zone) level=%s", level.name())
        show_msg("Cannot save  -- not at a friendly base!")
        return
    end
    -- In safe zone: cancel normal quicksave, redirect to our fixed file.
    flags.ret = true
    debug_log("on_before_save_input: redirecting quicksave -> %s (level=%s)", SAVE_FILENAME, level.name())
    save_extraction_slot()
    -- on_console_execute fires as part of save_extraction_slot(), sees our filename, passes.
end

-- Layer 2: redirect any Lua-initiated save that slipped past Layer 1.
-- Deletion of unauthorised saves (including raw C++ console writes to our slot)
-- is handled by enforce_single_mod_save_slot, scheduled from save_state and run
-- 1 second later so the .scop exists on disk before delete.
-- This callback only fires for saves initiated via exec_console_cmd (the Lua
-- wrapper in _g.script) -- direct C++ console input never reaches it.
local function on_console_execute(cmd, ...)
    if cmd ~= "save" then return end

    -- Recursion guard: save_extraction_slot() sets save_in_progress = true before calling
    -- exec_console_cmd, which fires this callback synchronously. If the flag is
    -- set we know this is our own intentional save  -- trust it and return.
    if save_in_progress then
        debug_log("on_console_execute: save_in_progress flag set -- this is our save, skipping")
        return
    end

    -- Any external Lua save (e.g. another mod calling exec_console_cmd("save ...")).
    -- If we are in a safe zone, redirect to our fixed filename; the subsequent
    -- enforce_single_mod_save_slot will delete any wrong-named file that was written.
    if get_friendly_safe_zone_actor_is_inside() then
        debug_log("on_console_execute: external save in safe zone -- redirecting to %s", SAVE_FILENAME)
        save_extraction_slot()
    end
    -- Outside a safe zone: do nothing here. enforce_single_mod_save_slot will
    -- delete whatever file the engine wrote.
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Death handling
-- ─────────────────────────────────────────────────────────────────────────────

local DEATH_FADE_ID = 5606 -- pp effector ID for death blackout (matches Jabbers)

-- Heal using direct property setters (confirmed from Jabbers Soulslike source).
-- change_bleeding() is NPC-only and crashes on db.actor; db.actor.bleeding = 0
-- via direct assignment works correctly. set_health_ex requires modded exes.
-- wounded(false) clears the wounded state set by the engine at the moment
-- health hits 0  -- without this, hurt sounds continue playing after respawn.
-- Confirmed from lua_help.script: `function wounded(boolean)` is a setter.
local function heal_actor()
    debug_log("heal_actor: restoring health/power/radiation/bleeding/psy_health/wounded")
    db.actor:set_health_ex(1.0)
    db.actor.power      = 1
    db.actor.radiation  = 0
    db.actor.bleeding   = 0
    db.actor.psy_health = 1
    db.actor:wounded(false)
end

-- Teleport and finalise the respawn. Called ~3s after inventory transfer completes.
--
-- TELEPORT STRATEGY  -- matches game_fast_travel.script:
--   Same level  → set_actor_position(pos)
--     ChangeLevel on the same level produces a "ghost camera" state  -- the level
--     reloads but the actor binder does not reinitialise correctly. The base game
--     uses set_actor_position for same-level travel.
--   Cross-level → ChangeLevel(pos, lvid, gvid, VEC_ZERO, false)
--     Required for inter-level teleportation. Nothing executes after it
--     (_g.script:407), so save/message must come first.
--
-- WHY invulnerable_time IS EXPIRED HERE:
--   While bind_stalker_ext.invulnerable_time is in the future, actor_on_update
--   forces bleeding=1 every frame, causing hurt sounds even after healing.
--   Setting it to time_global()+1 lets it expire immediately once the actor is
--   safely at the base. Pattern from Jabbers Soulslike OnRespawn().
--
-- HARD INVARIANT:
--   Same-level respawn after cancelled death uses black_infinite.ppe then
--   set_actor_position on this level. Do not end that path with only
--   level.remove_pp_effector(DEATH_FADE_ID) — Anomaly can leave movement and mouse
--   input disabled (HUD / input state wedged) until explicitly restored below.
--   This helper must: remove_pp_effector(DEATH_FADE_ID); level.enable_input() when
--   present; game.only_allow_movekeys(false) when game.only_movekeys_allowed();
--   level.show_weapon(true) when present (wrap optional APIs in pcall).
--   The same-level branch of complete_extraction_respawn must also schedule this
--   function again with CreateTimeEvent(..., 0, ...) after the first pass so cleanup
--   runs on the next ProcessEventQueue tick.
-- ─────────────────────────────────────────────────────────────────────────────

local function extraction_respawn_clear_death_fx_and_controls()
    level.remove_pp_effector(DEATH_FADE_ID)
    pcall(function()
        if level.enable_input then
            level.enable_input()
        end
    end)
    pcall(function()
        if game.only_movekeys_allowed and game.only_movekeys_allowed() then
            game.only_allow_movekeys(false)
        end
    end)
    pcall(function()
        if level.show_weapon then
            level.show_weapon(true)
        end
    end)
    return true
end

local function complete_extraction_respawn()
    debug_log("complete_extraction_respawn: fired")
    if not db.actor then
        debug_log("complete_extraction_respawn: db.actor is nil  -- aborting")
        return true
    end

    -- Use the hour cached at the moment of death in actor_on_before_death.
    -- level.get_time_hours() is unreliable by the time this deferred function
    -- fires -- the value observed in-game can differ from the time of death for
    -- reasons that are not fully understood. death_hour should always be set here
    -- because complete_extraction_respawn is only ever reached via the stash-poll chain
    -- started by actor_on_before_death, which sets death_hour first.
    if not death_hour then
        printe("![EM] complete_extraction_respawn: death_hour is nil -- this should never happen")
        return true
    end
    local hour = death_hour
    local delete_mode = delete_items_on_death_pending
    death_hour  = nil
    death_label = nil
    delete_items_on_death_pending = false
    debug_log("complete_extraction_respawn: hour at death=%d, is_night=%s", hour, tostring(is_night(hour)))
    if is_night(hour) then
        local hours = hours_until_dawn(hour)
        debug_log("complete_extraction_respawn: advancing time by %d hours to reach dawn", hours)
        if hours > 0 then
            level.change_game_time(0, hours, 0)
        end
    end

    heal_actor()

    -- Look up the zone by name to get current respawn coords. This means a
    -- dev_cli_set_zone_respawn() change takes effect on the next death without re-entering.
    -- actor_on_before_death already verified a valid base exists before queuing
    -- this deferred call, so base_zone should never be nil here.
    local base_zone = data.last_base_name and SAFE_ZONES_BY_NAME[data.last_base_name]
    if not base_zone then
        printe("![EM] complete_extraction_respawn: base_zone is nil -- this should not happen")
        extraction_respawn_clear_death_fx_and_controls()
        return true
    end

    local base_pos = vector():set(base_zone.respawn_x, base_zone.respawn_y, base_zone.respawn_z)
    local base_dir = base_zone.respawn_dir  -- nil = no direction override

    local current_level = level.name()
    debug_log("complete_extraction_respawn: base=%s current_level=%s base_level=%s",
        data.last_base_name, current_level, tostring(data.last_base_level))
    debug_log("complete_extraction_respawn: respawn=(%.2f, %.2f, %.2f) dir=%s lvid=%s gvid=%s",
        base_pos.x, base_pos.y, base_pos.z,
        base_dir and string.format("%.4f", base_dir) or "nil",
        tostring(data.last_base_lvid), tostring(data.last_base_gvid))

    if data.last_base_level == current_level then
        debug_log("complete_extraction_respawn: SAME-LEVEL respawn  -- using set_actor_position")
        db.actor:set_actor_position(base_pos)
        -- Apply configured facing direction, if any.
        -- set_actor_direction(number) confirmed on db.actor from sr_teleport.script.
        if base_dir then
            debug_log("complete_extraction_respawn: setting direction to %.4f rad", base_dir)
            db.actor:set_actor_direction(base_dir)
        end
        bind_stalker_ext.invulnerable_time = time_global() + 1
        debug_log("complete_extraction_respawn: invulnerable_time expired, removing fade, saving")
        extraction_respawn_clear_death_fx_and_controls()
        save_extraction_slot()
        if delete_mode then
            show_msg("You have died. Non-protected gear was destroyed.")
        else
            show_msg("You have died. Your gear marks the site of your death.")
        end
        -- HARD INVARIANT: second-tick pass required (see block above this helper).
        CreateTimeEvent("extraction_mod", "post_respawn_ctrl", 0, extraction_respawn_clear_death_fx_and_controls)
    else
        debug_log("complete_extraction_respawn: CROSS-LEVEL respawn  -- using ChangeLevel (nothing executes after)")
        -- Angle is the server actor o_Angle Fvector: x = pitch, y = yaw, z = roll
        -- (CALifeUpdateManager::change_level). Putting heading in .x was treated as
        -- pitch and produced a wrong/inverted camera until look input refreshed.
        -- All vanilla ChangeLevel angle args use VEC_ZERO; when respawn_dir is set,
        -- pass yaw in .y only (same heading scalar as set_actor_direction()).
        local angle = base_dir and vector():set(0, base_dir, 0) or VEC_ZERO
        debug_log("complete_extraction_respawn: angle pitch,yaw,roll=(0, %s, 0)",
            base_dir and string.format("%.4f", base_dir) or "0")
        if delete_mode then
            show_msg("You have died. Non-protected gear was destroyed.")
        else
            show_msg("You have died. Your gear marks the site of your death.")
        end
        ChangeLevel(base_pos, data.last_base_lvid, data.last_base_gvid, angle, false)
    end

    return true
end

-- Polls each tick until the spawned stash object comes online, then transfers
-- all actor inventory into it, then queues the respawn timer.
-- Returns false to keep polling, true when done (CreateTimeEvent contract).
-- Pattern confirmed from Jabbers Soulslike HandleItemsAndRespawn source.
local function poll_death_stash_transfer_and_queue_respawn(stash_id)
    local stash = level.object_by_id(stash_id)
    if not stash then
        debug_log("poll_death_stash_transfer_and_queue_respawn: stash id=%s not online yet  -- polling", tostring(stash_id))
        return false -- not online yet, poll again next tick
    end

    debug_log("poll_death_stash_transfer_and_queue_respawn: stash id=%s is ONLINE  -- transferring items", tostring(stash_id))

    -- Transfer all items from actor into the stash container, except those
    -- listed in keep_on_death (e.g. the PDA).
    -- db.actor:transfer_item(item, container) confirmed from Jabbers source.
    -- Collect into a table first to avoid modifying inventory mid-iteration.
    local items = collect_actor_inventory_excluding_keep_on_death()

    debug_log("poll_death_stash_transfer_and_queue_respawn: transferring %d items to stash", #items)
    for _, item in ipairs(items) do
        debug_log("poll_death_stash_transfer_and_queue_respawn: transferring item '%s'", item:section())
        db.actor:transfer_item(item, stash)
    end

    debug_log("poll_death_stash_transfer_and_queue_respawn: transfer complete  -- queuing respawn in 3s")

    data.death_stash_ids[stash_id] = true
    debug_log("poll_death_stash_transfer_and_queue_respawn: registered death_stash id=%d", stash_id)

    -- Add a PDA map marker so the player can find their stash after respawn.
    -- Uses "secondary_task_location" spot type (confirmed from soulslike_scenarios.script).
    -- map_add_object_spot_ser persists the marker in the save file.
    -- The marker is removed in actor_on_item_take_from_box when the player loots the stash.
    if mcm_option("show_stash_marker") then
        -- Use the in-game date/time captured at the moment of death (e.g.
        -- "Death: 14.04.2012 21:33"). Falls back to a generic label if somehow
        -- death_label was not set (should not happen in normal flow).
        local label = death_label or "Death stash"
        level.map_add_object_spot_ser(stash_id, "secondary_task_location", label)
        data.stash_ids[stash_id] = true
        debug_log("poll_death_stash_transfer_and_queue_respawn: added PDA marker for stash id=%d label='%s'", stash_id, label)
    end

    -- Respawn 3 seconds after items are transferred  -- gives the fade time to play.
    CreateTimeEvent("extraction_mod", "respawn", 3, complete_extraction_respawn)
    return true
end

-- If one of our tracked stashes is emptied by the player, clean it up.
-- This runs deferred by one tick to avoid mutating stash state during UI teardown.
local function actor_on_item_take_from_box(box, obj)
    local id = box:id()
    if not (data.stash_ids[id] or data.death_stash_ids[id]) then return end
    -- Defer stash-empty handling by one tick so we do not mutate marker/release
    -- state while inventory UI is being torn down.
    CreateTimeEvent("extraction_mod", "player_emptied_stash_" .. tostring(id), 0, function()
        remove_empty_death_stash(id, "extraction_mod_player_emptied")
        return true
    end)
end

-- Requires modded exes. flags.ret_value = false cancels the death event.
local function actor_on_before_death(who_id, flags)
    debug_log("actor_on_before_death: fired  -- who_id=%s", tostring(who_id))

    -- If the player has never reached a safe zone there is no respawn point.
    -- Delete any existing mod save before allowing the death so the player
    -- cannot cheat by deliberately unsetting their spawn to reload an old save.
    local base_zone = data.last_base_name and SAFE_ZONES_BY_NAME[data.last_base_name]
    if not base_zone then
        debug_log("actor_on_before_death: no base on record -- deleting save and allowing death (game over)")
        ui_load_dialog.delete_save_game(SAVE_FILENAME)
        return
    end

    -- Cache the time of death NOW, before any engine state changes.
    -- The engine appears to restore the last save's time as part of processing
    -- the cancelled death, so level.get_time_hours() returns a stale/wrong value
    -- by the time complete_extraction_respawn fires a few seconds later.
    death_hour = level.get_time_hours()
    debug_log("actor_on_before_death: death_hour=%d (cached before engine state changes)", death_hour)

    -- Build a human-readable in-game date/time label for the PDA stash marker.
    -- CTime:get() returns Y,M,D,h,m,s,ms (all as numbers).
    -- Pattern from utils_data.CTime_to_table().
    do
        local t = game.get_game_time()
        local Y, Mo, D, h, m, s, ms = 0, 0, 0, 0, 0, 0, 0
        Y, Mo, D, h, m, s, ms = t:get(Y, Mo, D, h, m, s, ms)
        death_label = string.format("Death: %02d.%02d.%04d %02d:%02d", D, Mo, Y, h, m)
        debug_log("actor_on_before_death: death_label='%s'", death_label)
    end
    delete_items_on_death_pending = mcm_option("delete_items_on_death")
    debug_log("actor_on_before_death: delete_items_on_death=%s", tostring(delete_items_on_death_pending))

    flags.ret_value = false
    debug_log("actor_on_before_death: flags.ret_value set to false (death cancelled)")

    -- Invulnerability: actor_on_update forces health=1 while this is in the future,
    -- preventing re-death from residual damage during the respawn sequence.
    -- Pattern confirmed from Jabbers Soulslike OnDeath().
    bind_stalker_ext.invulnerable_time = time_global() + 30000
    debug_log("actor_on_before_death: invulnerable_time set (+30s)")

    -- Restore health immediately so g_Alive() returns true.
    -- g_Alive() == `GetfHealth() > 0` (Entity.h:90)  -- health is 0 at this point.
    db.actor:set_health_ex(1.0)
    debug_log("actor_on_before_death: health restored to 1.0")

    -- Fade to black.
    level.add_pp_effector("black_infinite.ppe", DEATH_FADE_ID, true)
    debug_log("actor_on_before_death: fade to black started (effector id=%d)", DEATH_FADE_ID)

    -- Count transferable items (excluding keep_on_death sections) before
    -- deciding whether to spawn a stash.
    local items = collect_actor_inventory_excluding_keep_on_death()
    db.actor:iterate_inventory(function(_, obj)
        if keep_on_death[obj:section()] then
            debug_log("actor_on_before_death: keeping '%s' (in keep_on_death)", obj:section())
        end
    end, nil)
    debug_log("actor_on_before_death: transferable item count=%d", #items)

    if #items == 0 then
        debug_log("actor_on_before_death: inventory empty  -- skipping stash, respawn in 3s")
        CreateTimeEvent("extraction_mod", "respawn", 3, complete_extraction_respawn)
        return
    end

    if delete_items_on_death_pending then
        debug_log("actor_on_before_death: deleting %d non-protected item(s)", #items)
        for _, item in ipairs(items) do
            debug_log("actor_on_before_death: deleting item '%s'", item:section())
            alife_release(item)
        end
        CreateTimeEvent("extraction_mod", "respawn", 3, complete_extraction_respawn)
        return
    end

    -- Spawn stash at death position, poll until online, transfer items, respawn.
    -- [GAP-2] "inv_backpack" section name confirmed from Jabbers source.
    local death_pos  = db.actor:position()
    local death_lvid = db.actor:level_vertex_id()
    local death_gvid = db.actor:game_vertex_id()
    debug_log("actor_on_before_death: death pos=(%.2f, %.2f, %.2f) lvid=%s gvid=%s level=%s",
        death_pos.x, death_pos.y, death_pos.z,
        tostring(death_lvid), tostring(death_gvid), level.name())

    local se_stash = alife_create("inv_backpack", death_pos, death_lvid, death_gvid)
    if se_stash then
        debug_log("actor_on_before_death: stash created, server id=%s  -- polling for online", tostring(se_stash.id))
        CreateTimeEvent("extraction_mod", "wait_stash", 0, poll_death_stash_transfer_and_queue_respawn, se_stash.id)
    else
        debug_log("actor_on_before_death: stash creation FAILED  -- skipping item transfer, respawn in 3s")
        CreateTimeEvent("extraction_mod", "respawn", 3, complete_extraction_respawn)
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Level transition tracking
-- ─────────────────────────────────────────────────────────────────────────────

-- Fires before the level unloads. We write a flag file here so that
-- actor_on_first_update on the new level knows THIS session caused the
-- transition and can safely delete the engine's autosave.
--
-- The flag is a plain file in the saves folder ("em_transition_flag").
-- actor_on_first_update deletes it after reading it, so it never accumulates.
local function on_level_changing()
    first_update_done = false
    was_in_safe_zone = false
    clear_safe_zone_restrictor_state()

    -- Write "1" to the flag file. actor_on_first_update reads this and resets
    -- it to "0" after consuming it, so the file persists as a persistent
    -- on/off indicator across level transitions.
    -- NOTE: os.remove is not available in Anomaly's Lua sandbox, so we cannot
    -- delete the file. We use content ("1"/"0") to track state instead.
    local flag_path = get_flag_path()
    debug_log("on_level_changing: writing transition flag to '%s'", flag_path)
    local f = io.open(flag_path, "w")
    if f then
        f:write("1")
        f:close()
    else
        printe("![EM] on_level_changing: failed to write transition flag to '%s'", flag_path)
    end
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Initialisation
-- ─────────────────────────────────────────────────────────────────────────────

local first_update_done    = false

local function on_option_change()
    refresh_stash_loot_delete_chance_percent("on_option_change")
end

local function actor_on_first_update()
    if first_update_done then return end
    first_update_done = true
    debug_log("actor_on_first_update: first update fired (level=%s)", level.name())

    -- [GAP-8] Level-transition autosave cleanup.
    -- The C++ engine writes user_name() .. " - autosave" during every level
    -- transition (alife_update_manager.cpp:219). on_console_execute fires as a
    -- pre-notification before the file exists, so delete_save_game there is a
    -- no-op. By the time actor_on_first_update fires the file is on disk.
    --
    -- We only delete the engine's autosave when we know THIS session triggered
    -- the transition. on_level_changing writes a flag file to the saves folder
    -- before the transition; we check for it here and remove it.
    --
    -- Why the flag is necessary: user_name() returns the Windows display name
    -- (Core.UserName), which does not change between playthroughs. A pre-existing
    -- "player - autosave" from a different playthrough would be silently deleted
    -- if we always called delete_save_game unconditionally on first update.
    -- The flag proves that the current session is responsible for the file.
    do
        -- Read the flag file. "1" means on_level_changing wrote it this session.
        -- os.remove is not available in Anomaly's Lua sandbox, so we reset the
        -- flag by overwriting with "0" rather than deleting the file.
        local flag_path = get_flag_path()
        local f = io.open(flag_path, "r")
        local flag_val = f and f:read("*l") or "0"
        if f then f:close() end

        if flag_val == "1" then
            -- Consume the flag.
            local fw = io.open(flag_path, "w")
            if fw then fw:write("0"); fw:close() end
            local autosave_name = string.lower(user_name()) .. " - autosave"
            debug_log("actor_on_first_update: transition flag found -- deleting engine autosave '%s'", autosave_name)
            ui_load_dialog.delete_save_game(autosave_name)
        else
            debug_log("actor_on_first_update: no transition flag (val='%s') -- skipping autosave cleanup", flag_val)
            -- Only treat this as suspicious when a save was actually loaded in
            -- this session. Starting a brand-new game should never be tainted by
            -- stale lock state from a previous run.
            local main_menu_load_flag = read_main_menu_load_flag()
            if load_state_seen_this_session
                and read_session_lock_flag() == "1"
                and main_menu_load_flag ~= "1" then
                mark_run_tainted_by_forbidden_load("session lock active without level transition")
            end
            -- Consume the flag whether or not we used it.
            write_main_menu_load_flag("0")
        end
        -- Guard snapshots are strictly temporary and should never survive level
        -- loads. A transition can interrupt the deferred save-cleanup timer that
        -- normally deletes SLOT_GUARD_STEM; purge it deterministically here.
        ui_load_dialog.delete_save_game(SLOT_GUARD_STEM)
        -- Mark current session active after load completes.
        write_session_lock_flag("1")
        -- No save_extraction_slot() here: the existing em_extraction_save from before the
        -- transition is still valid. The player saves manually when inside a base.
    end

    ensure_safe_zone_restrictors_for_level()
    refresh_safe_zone_restrictor_callbacks()

    if not data.first_run_migration_done then
        debug_log("actor_on_first_update: first-run migration bootstrap starting")
        local moved_ok = migrate_all_existing_saves_to_first_run_backup()
        if moved_ok then
            -- First-run bootstrap must seed extraction save even outside safe zones.
            suppress_external_save_cleanup_once = true
            save_extraction_slot()
            data.first_run_migration_done = true
            show_msg("Extraction first-run setup complete: saves were backed up and extraction save initialized.")
            debug_log("actor_on_first_update: first-run migration bootstrap complete")
        else
            show_msg("Extraction first-run setup failed: could not back up existing saves.")
            printe("![EM] actor_on_first_update: first-run migration failed -- marker not set")
        end
    end

    -- First-spawn convenience: if no base has ever been recorded yet and the
    -- actor already spawned inside a friendly safe zone, capture it immediately.
    if not data.last_base_name then
        local zone = get_friendly_safe_zone_actor_is_inside()
        if zone then
            record_respawn_base_from_zone(zone)
            debug_log("actor_on_first_update: auto-set initial base to '%s'", tostring(zone.name))
            show_msg("Initial respawn base set to current safe zone.")
        else
            debug_log("actor_on_first_update: no base on record -- player must visit a safe zone")
        end
    else
        debug_log("actor_on_first_update: base on record: %s (level=%s)",
            data.last_base_name, tostring(data.last_base_level))
    end

    show_msg("Extraction mode active. Saves only at friendly bases.")
end

-- ─────────────────────────────────────────────────────────────────────────────
-- Registration   (docs: scripting/callbacks.md)
-- ─────────────────────────────────────────────────────────────────────────────

function on_game_start()
    debug_log("on_game_start: registering callbacks")
    load_state_seen_this_session = false
    data.tainted_by_forbidden_load = false
    next_taint_warning_ms = nil
    load_config()
    if not pending_release_timer_started then
        CreateTimeEvent("extraction_mod", "pending_stash_release", STASH_RELEASE_FLUSH_INTERVAL_SEC,
            tick_pending_death_stash_releases)
        pending_release_timer_started = true
    end

    -- Patch UILoadDialog.load_game_internal to block in-game loads.
    -- We replace the method on the class table directly rather than wrapping
    -- exec_console_cmd globally, because xray-monolith gives each script its
    -- own environment table -- our module's assignment to exec_console_cmd is
    -- not visible to ui_load_dialog.script's global lookup.
    -- Replacing the method on the shared class object is visible to all callers.
    -- Guard against double-patching if on_game_start fires more than once.
    if not orig_load_game_internal then
        -- Referencing ui_load_dialog.UILoadDialog forces the script to load if
        -- it hasn't been loaded yet. After this line the class table exists.
        local cls = ui_load_dialog.UILoadDialog
        if cls then
            orig_load_game_internal = cls.load_game_internal
            cls.load_game_internal = function(self_dlg)
                -- Block only when a live session is active. db.actor is nil at
                -- the main menu, so loads from there are always allowed through.
                if db.actor and db.actor:alive() then
                    show_msg("Cannot load -- extraction mode is active!")
                    debug_log("UILoadDialog.load_game_internal: BLOCKED")
                    return
                end
                -- Main-menu initiated load path: mark it so actor_on_first_update
                -- can distinguish legit recovery loads from in-session console loads.
                write_main_menu_load_flag("1")
                return orig_load_game_internal(self_dlg)
            end
            debug_log("on_game_start: UILoadDialog.load_game_internal patched")
        else
            printe("![EM] on_game_start: ui_load_dialog.UILoadDialog not found -- ESC menu load blocking unavailable")
        end
    end

    RegisterScriptCallback("actor_on_first_update", actor_on_first_update)
    RegisterScriptCallback("actor_on_update", actor_on_update)
    RegisterScriptCallback("actor_on_before_death", actor_on_before_death)
    RegisterScriptCallback("actor_on_item_take_from_box", actor_on_item_take_from_box)
    RegisterScriptCallback("on_before_load_input", on_before_load_input)
    RegisterScriptCallback("on_before_save_input", on_before_save_input)
    RegisterScriptCallback("on_console_execute", on_console_execute)
    RegisterScriptCallback("on_level_changing", on_level_changing)
    RegisterScriptCallback("on_option_change", on_option_change)
    RegisterScriptCallback("on_key_press", extraction_mod_on_key_press)
    RegisterScriptCallback("save_state", save_state)
    RegisterScriptCallback("load_state", load_state)
    refresh_stash_loot_delete_chance_percent("on_game_start")
end

function on_game_end()
    debug_log("on_game_end: unregistering callbacks and resetting state")
    first_update_done = false
    last_check_time   = 0
    last_safe_zone_restrictor_bind_poll_time = 0
    was_in_safe_zone  = false
    next_taint_warning_ms = nil
    load_state_seen_this_session = false
    death_hour        = nil
    death_label       = nil
    delete_items_on_death_pending = false
    data.stash_ids              = {}
    data.death_stash_ids        = {}
    data.pending_stash_release_ids = {}
    data.last_stash_loot_game_ms = nil
    data.safe_zone_restrictor_ids = {}
    data.tainted_by_forbidden_load = false
    SAFE_ZONES_BY_RESTRICTOR_ID    = {}
    ACTOR_INSIDE_SAFE_ZONE_IDS  = {}
    SAFE_ZONE_RESTRICTOR_CALLBACKS_DONE = {}
    SAFE_ZONE_RESTRICTOR_SEED_DONE = {}
    pending_release_timer_started = false
    external_save_cleanup_ctx = nil
    if ui_load_dialog then
        ui_load_dialog.delete_save_game(SLOT_GUARD_STEM)
    end
    -- Best effort session-end marker. (If the process crashes this may remain "1".)
    write_session_lock_flag("0")

    -- Restore UILoadDialog.load_game_internal to the original method.
    if orig_load_game_internal then
        local cls = ui_load_dialog and ui_load_dialog.UILoadDialog
        if cls then
            cls.load_game_internal = orig_load_game_internal
        end
        orig_load_game_internal = nil
    end

    UnregisterScriptCallback("actor_on_first_update", actor_on_first_update)
    UnregisterScriptCallback("actor_on_update", actor_on_update)
    UnregisterScriptCallback("actor_on_before_death", actor_on_before_death)
    UnregisterScriptCallback("actor_on_item_take_from_box", actor_on_item_take_from_box)
    UnregisterScriptCallback("on_before_load_input", on_before_load_input)
    UnregisterScriptCallback("on_before_save_input", on_before_save_input)
    UnregisterScriptCallback("on_console_execute", on_console_execute)
    UnregisterScriptCallback("on_level_changing", on_level_changing)
    UnregisterScriptCallback("on_option_change", on_option_change)
    UnregisterScriptCallback("on_key_press", extraction_mod_on_key_press)
    UnregisterScriptCallback("save_state", save_state)
    UnregisterScriptCallback("load_state", load_state)
end
