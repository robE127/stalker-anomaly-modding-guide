-- extraction_mod_mcm.script
-- MCM registration for Extraction Mod.
-- MCM scans all scripts at startup for files ending in _mcm.script and calls
-- on_mcm_load(). The returned table defines the settings UI.

function on_mcm_load()
    return {
        id = "extraction_mod",
        sh = true,
        gr = {
            {
                id   = "ui_section_options",
                type = "title",
                text = "ui_mcm_extraction_mod_section_options",
            },
            {
                id      = "allow_neutral_bases",
                type    = "check",
                val     = 1,
                def     = false,
                text    = "ui_mcm_extraction_mod_allow_neutral_bases",
            },
            {
                id      = "delete_items_on_death",
                type    = "check",
                val     = 1,
                def     = false,
                text    = "ui_mcm_extraction_mod_delete_items_on_death",
            },
            {
                id      = "show_stash_marker",
                type    = "check",
                val     = 1,       -- 1 = boolean type
                def     = true,
                text    = "ui_mcm_extraction_mod_show_stash_marker",
            },
            {
                id      = "stash_npc_looting",
                type    = "check",
                val     = 1,
                def     = false,
                text    = "ui_mcm_extraction_mod_stash_npc_looting",
            },
            {
                id   = "stash_loot_interval_hours",
                type = "input",
                val  = 0,
                def  = "1",
                text = "ui_mcm_extraction_mod_stash_loot_interval_hours",
            },
            {
                id   = "stash_loot_delete_chance_percent",
                type = "input",
                val  = 0,
                def  = "25",
                text = "ui_mcm_extraction_mod_stash_loot_delete_chance_percent",
            },
            {
                id   = "ui_section_hotkeys",
                type = "title",
                text = "ui_mcm_extraction_mod_section_hotkeys",
            },
            {
                id   = "base_hotkey",
                type = "key_bind",
                val  = 2,
                def  = DIK_keys.DIK_F8,
                text = "ui_mcm_extraction_mod_base_hotkey",
            },
        }
    }
end
